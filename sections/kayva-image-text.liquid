{{ 'kayva.css' | asset_url | stylesheet_tag }}
<style>
.kv-imgtext-grid{display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:center;}
.kv-imgtext-grid--rev .kv-imgtext-media{order:2;}
.kv-imgtext-grid--rev .kv-imgtext-content{order:1;}
.kv-imgtext-media{overflow:hidden;background:var(--kayva-cream);aspect-ratio:{{section.settings.ratio}};}
.kv-imgtext-media img{width:100%;height:100%;object-fit:cover;}
.kv-imgtext-content{display:flex;flex-direction:column;gap:18px;}
.kv-imgtext-heading{font-family:var(--kayva-font);font-weight:600;font-size:clamp(22px,3vw,32px);color:{{section.settings.text_color}};line-height:1.25;}
.kv-imgtext-body{font-family:var(--kayva-font);font-size:15px;color:{{section.settings.text_color}};opacity:.8;line-height:1.75;}
@media(max-width:768px){.kv-imgtext-grid,.kv-imgtext-grid--rev{grid-template-columns:1fr;gap:32px;}
.kv-imgtext-grid--rev .kv-imgtext-media,.kv-imgtext-grid--rev .kv-imgtext-content{order:unset;}}
</style>

<section style="background:{{section.settings.bg}};padding:80px 0;">
  <div class="kayva-page-width">
    <div class="kv-imgtext-grid{% if section.settings.image_side == 'right' %} kv-imgtext-grid--rev{% endif %}">
      <div class="kv-imgtext-media">
        {%- if section.settings.image != blank -%}
          <img src="{{section.settings.image | image_url: width:1000}}" alt="{{section.settings.image.alt | escape}}" loading="lazy">
        {%- else -%}
          {{  'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="kv-imgtext-content">
        {%- if section.settings.eyebrow != blank -%}<span class="kayva-eyebrow">{{section.settings.eyebrow}}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="kv-imgtext-heading">{{section.settings.heading}}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="kv-imgtext-body">{{section.settings.text}}</div>{%- endif -%}
        {%- if section.settings.btn_label != blank -%}
          <div><a href="{{section.settings.btn_url}}" class="kayva-btn kayva-btn--primary">{{section.settings.btn_label}}</a></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{"name":"KAYVA Image with Text","settings":[
{"type":"image_picker","id":"image","label":"Image"},
{"type":"select","id":"ratio","label":"Image ratio","options":[{"value":"1 / 1","label":"Square"},{"value":"4 / 5","label":"Portrait 4:5"},{"value":"3 / 2","label":"Landscape 3:2"}],"default":"4 / 5"},
{"type":"select","id":"image_side","label":"Image position","options":[{"value":"left","label":"Left"},{"value":"right","label":"Right"}],"default":"left"},
{"type":"text","id":"eyebrow","label":"Eyebrow"},
{"type":"textarea","id":"heading","label":"Heading","default":"Fewer lumens, better light."},
{"type":"richtext","id":"text","label":"Body","default":"<p>Ra95+ means your colours render the way they should.</p>"},
{"type":"text","id":"btn_label","label":"Button label"},
{"type":"url","id":"btn_url","label":"Button URL"},
{"type":"color","id":"bg","label":"Background","default":"#F5EFE5"},
{"type":"color","id":"text_color","label":"Text colour","default":"#3D2A15"}
],"presets":[{"name":"KAYVA Image with Text"}]}
{% endschema %}
