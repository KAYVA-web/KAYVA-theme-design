{{ 'kayva.css' | asset_url | stylesheet_tag }}

<style>
.kv-bundle-{{ section.id }} { font-family: var(--kayva-font); background: {{ section.settings.background_color }}; }
.kv-bundle__head { text-align: center; max-width: 640px; margin: 0 auto 48px; }
.kv-bundle__eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--kayva-amber, #B8753A);
  margin-bottom: 12px;
}
.kv-bundle__heading {
  font-size: clamp(24px, 3.2vw, 36px);
  font-weight: 300;
  letter-spacing: -0.4px;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 12px;
  line-height: 1.15;
}
.kv-bundle__sub {
  font-size: 16px;
  line-height: 1.65;
  color: var(--kayva-warm-brown, #6B4823);
}

.kv-bundle__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
@media (max-width: 900px) { .kv-bundle__grid { grid-template-columns: 1fr; max-width: 440px; margin: 0 auto; } }

.kv-bundle__card {
  display: flex;
  flex-direction: column;
  background: var(--kayva-white, #FFFFFF);
  border: 1.5px solid var(--kayva-line, #E8E0D2);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
  transition: border-color 0.2s, transform 0.2s;
}
.kv-bundle__card:hover { border-color: var(--kayva-dark-brown, #3D2A15); transform: translateY(-2px); }
.kv-bundle__card.is-featured { border-color: var(--kayva-amber, #B8753A); border-width: 2px; }

.kv-bundle__badge {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 2;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--kayva-cream, #F5EFE5);
  background: var(--kayva-amber, #B8753A);
  padding: 6px 12px;
  border-radius: 2px;
}

.kv-bundle__image {
  aspect-ratio: 1 / 1;
  background: var(--kayva-cream, #F5EFE5);
  display: block;
}
.kv-bundle__image img { width: 100%; height: 100%; object-fit: contain; display: block; }

.kv-bundle__body { padding: 24px 24px 28px; display: flex; flex-direction: column; flex: 1; }
.kv-bundle__name {
  font-size: 20px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 6px;
}
.kv-bundle__desc {
  font-size: 14px;
  line-height: 1.6;
  color: var(--kayva-warm-brown, #6B4823);
  margin-bottom: 18px;
}

.kv-bundle__includes {
  list-style: none;
  margin: 0 0 24px;
  padding: 0;
  display: grid;
  gap: 10px;
  flex: 1;
}
.kv-bundle__includes li {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  font-size: 14px;
  line-height: 1.5;
  color: var(--kayva-warm-brown, #6B4823);
}
.kv-bundle__includes svg { flex-shrink: 0; margin-top: 3px; color: var(--kayva-amber, #B8753A); }

/* Footer: price + buy now, pinned to bottom like Govee bundle cards */
.kv-bundle__footer {
  margin-top: auto;
  padding-top: 20px;
  border-top: 1px solid var(--kayva-line, #E8E0D2);
}
.kv-bundle__price-row {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin-bottom: 14px;
}
.kv-bundle__price {
  font-size: 22px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
}
.kv-bundle__price-compare {
  font-size: 15px;
  color: var(--kayva-soft-brown, #8A5524);
  text-decoration: line-through;
}
.kv-bundle__save {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--kayva-amber, #B8753A);
}
.kv-bundle__buy {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 2px;
  background: var(--kayva-dark-brown, #3D2A15);
  color: var(--kayva-cream, #F5EFE5);
  font-family: var(--kayva-font);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.2s;
}
.kv-bundle__buy:hover { background: var(--kayva-warm-brown, #6B4823); }
.kv-bundle__buy[disabled],
.kv-bundle__buy.is-disabled {
  background: var(--kayva-soft-brown, #8A5524);
  pointer-events: none;
}
</style>

<div class="kv-bundle-{{ section.id }}">
  <div class="kayva-page-width" style="padding: 72px 24px;">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="kv-bundle__head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="kv-bundle__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kv-bundle__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="kv-bundle__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kv-bundle__grid">
      {%- for block in section.blocks -%}
        {%- assign bp = block.settings.product -%}
        <div class="kv-bundle__card{% if block.settings.featured %} is-featured{% endif %}" {{ block.shopify_attributes }}>

          {%- if block.settings.badge != blank -%}
            <span class="kv-bundle__badge">{{ block.settings.badge }}</span>
          {%- endif -%}

          <a href="{{ bp.url }}" class="kv-bundle__image">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ bp.title | escape }}" loading="lazy">
            {%- elsif bp.featured_image -%}
              <img src="{{ bp.featured_image | image_url: width: 800 }}" alt="{{ bp.featured_image.alt | escape }}" loading="lazy">
            {%- endif -%}
          </a>

          <div class="kv-bundle__body">
            <h3 class="kv-bundle__name">
              {%- if block.settings.name != blank -%}{{ block.settings.name }}{%- else -%}{{ bp.title }}{%- endif -%}
            </h3>
            {%- if block.settings.desc != blank -%}
              <p class="kv-bundle__desc">{{ block.settings.desc }}</p>
            {%- endif -%}

            {%- if block.settings.includes != blank -%}
              <ul class="kv-bundle__includes">
                {%- assign items = block.settings.includes | newline_to_br | split: '<br />' -%}
                {%- for item in items -%}
                  {%- assign item_clean = item | strip -%}
                  {%- if item_clean != blank -%}
                    <li>
                      <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.2 3.2L13 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      <span>{{ item_clean }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <!-- Price + Buy now pinned to the bottom of the card, Govee-style -->
            <div class="kv-bundle__footer">
              {%- if bp != blank -%}
                <div class="kv-bundle__price-row">
                  {%- if bp.price_varies -%}
                    <span class="kv-bundle__save" style="text-transform:uppercase;">From</span>
                    <span class="kv-bundle__price">{{ bp.price_min | money }}</span>
                  {%- else -%}
                    <span class="kv-bundle__price">{{ bp.price | money }}</span>
                  {%- endif -%}
                  {%- if bp.compare_at_price > bp.price -%}
                    <span class="kv-bundle__price-compare">{{ bp.compare_at_price | money }}</span>
                    <span class="kv-bundle__save">Save {{ bp.compare_at_price | minus: bp.price | money }}</span>
                  {%- endif -%}
                </div>
                <a href="{{ bp.url }}" class="kv-bundle__buy{% unless bp.available %} is-disabled{% endunless %}">
                  {%- if bp.available -%}
                    {{ block.settings.buy_label | default: 'Buy now' }}
                  {%- else -%}
                    {{ section.settings.sold_out_label | default: 'Sold out' }}
                  {%- endif -%}
                </a>
              {%- else -%}
                <p class="kv-bundle__desc">Select a product for this bundle in the theme editor.</p>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "KAYVA Bundle Showcase",
  "max_blocks": 3,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#F5EFE5"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "BUNDLE & SAVE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build your setup."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pick the bundle that matches your room. Each one is priced to save you more than buying separately."
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Sold out label",
      "default": "Sold out"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Bundle product",
          "info": "Link to the bundle's own product page (not a single variant) — each bundle should be its own product so it has its own price, image and inventory."
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Highlight as featured / most popular",
          "default": false
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "info": "e.g. MOST POPULAR, BEST VALUE"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Leave blank to use the product's featured image."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Display name",
          "info": "Leave blank to use the product title."
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Short description"
        },
        {
          "type": "textarea",
          "id": "includes",
          "label": "What's included (one item per line)",
          "default": "1x KAYVA 480 Pro Strip (5m)\n1x 24V Driver\n1x Aluminium Channel + Diffuser"
        },
        {
          "type": "text",
          "id": "buy_label",
          "label": "Buy button label",
          "default": "Buy now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KAYVA Bundle Showcase",
      "settings": {
        "background_color": "#F5EFE5",
        "eyebrow": "BUNDLE & SAVE",
        "heading": "Build your setup.",
        "subheading": "Pick the bundle that matches your room. Each one is priced to save you more than buying separately.",
        "sold_out_label": "Sold out"
      },
      "blocks": [
        {
          "type": "bundle",
          "settings": {
            "name": "Bundle 1 — Starter",
            "badge": "GOOD",
            "desc": "For a single accent wall or shelf run.",
            "includes": "1x KAYVA 480 Pro Strip (3m)\n1x 24V Driver\n1x Aluminium Channel + Diffuser",
            "buy_label": "Buy now"
          }
        },
        {
          "type": "bundle",
          "settings": {
            "featured": true,
            "name": "Bundle 2 — Pro",
            "badge": "MOST POPULAR",
            "desc": "Our most-bought setup — enough for a full room run.",
            "includes": "1x KAYVA 480 Pro Strip (5m)\n1x 24V Driver\n1x Aluminium Channel + Diffuser\n1x TRIAC Wall Dimmer",
            "buy_label": "Buy now"
          }
        },
        {
          "type": "bundle",
          "settings": {
            "name": "Bundle 3 — Complete Room",
            "badge": "BEST VALUE",
            "desc": "Everything for a full room, multiple runs included.",
            "includes": "2x KAYVA 480 Pro Strip (5m)\n2x 24V Driver\n2x Aluminium Channel + Diffuser\n1x TRIAC Wall Dimmer\n1x Connector Kit",
            "buy_label": "Buy now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
