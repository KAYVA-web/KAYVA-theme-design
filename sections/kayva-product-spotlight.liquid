{{ 'kayva.css' | asset_url | stylesheet_tag }}

<style>
.kv-spot-{{ section.id }} { font-family: var(--kayva-font); background: {{ section.settings.background_color }}; }

/* Feature row (alternating image/text, Govee-style) */
.kv-spot__feature {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  padding: 72px 0;
}
.kv-spot__feature--reverse .kv-spot__feature-media { order: 2; }
.kv-spot__feature--reverse .kv-spot__feature-copy { order: 1; }
.kv-spot__feature-media img,
.kv-spot__feature-media video {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 4px;
}
.kv-spot__feature-eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--kayva-amber, #B8753A);
  margin-bottom: 14px;
}
.kv-spot__feature-title {
  font-size: clamp(24px, 3.2vw, 36px);
  font-weight: 300;
  letter-spacing: -0.4px;
  line-height: 1.15;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 16px;
}
.kv-spot__feature-text {
  font-size: 16px;
  line-height: 1.75;
  color: var(--kayva-warm-brown, #6B4823);
  max-width: 480px;
}
.kv-spot__feature-text p { margin-bottom: 12px; }

@media (max-width: 768px) {
  .kv-spot__feature,
  .kv-spot__feature--reverse {
    grid-template-columns: 1fr;
    gap: 28px;
    padding: 48px 0;
  }
  .kv-spot__feature--reverse .kv-spot__feature-media,
  .kv-spot__feature--reverse .kv-spot__feature-copy { order: initial; }
}

/* Spec table */
.kv-spot__specs { padding: 64px 0; }
.kv-spot__specs-title {
  font-size: clamp(22px, 2.8vw, 30px);
  font-weight: 300;
  color: var(--kayva-dark-brown, #3D2A15);
  text-align: center;
  margin-bottom: 36px;
}
.kv-spot__specs-table { width: 100%; max-width: 720px; margin: 0 auto; border-collapse: collapse; }
.kv-spot__specs-table tr { border-bottom: 1px solid var(--kayva-line, #E8E0D2); }
.kv-spot__specs-table tr:last-child { border-bottom: none; }
.kv-spot__specs-table td {
  padding: 16px 14px;
  font-size: 15px;
  line-height: 1.5;
  color: var(--kayva-warm-brown, #6B4823);
}
.kv-spot__specs-table td:first-child {
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  width: 38%;
  letter-spacing: 0.02em;
}

/* Gallery strip */
.kv-spot__gallery { padding: 64px 0; }
.kv-spot__gallery-title {
  font-size: clamp(22px, 2.8vw, 30px);
  font-weight: 300;
  color: var(--kayva-dark-brown, #3D2A15);
  text-align: center;
  margin-bottom: 36px;
}
.kv-spot__gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.kv-spot__gallery-grid img {
  width: 100%;
  height: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 4px;
  display: block;
}
@media (max-width: 600px) {
  .kv-spot__gallery-grid { grid-template-columns: repeat(2, 1fr); }
}

/* Banner CTA */
.kv-spot__banner {
  position: relative;
  padding: 96px 24px;
  text-align: center;
  border-radius: 4px;
  overflow: hidden;
  background-size: cover;
  background-position: center;
}
.kv-spot__banner-overlay {
  position: absolute;
  inset: 0;
  background: rgba(61,42,21,0.45);
}
.kv-spot__banner-inner { position: relative; z-index: 1; }
.kv-spot__banner-eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--kayva-cream, #F5EFE5);
  margin-bottom: 14px;
}
.kv-spot__banner-title {
  font-size: clamp(26px, 4vw, 42px);
  font-weight: 300;
  color: var(--kayva-cream, #F5EFE5);
  margin-bottom: 14px;
  line-height: 1.15;
}
.kv-spot__banner-text {
  font-size: 16px;
  color: rgba(245,239,229,0.8);
  max-width: 540px;
  margin: 0 auto 28px;
  line-height: 1.6;
}
</style>

<div class="kv-spot-{{ section.id }}">
  <div class="kayva-page-width">

    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'feature' -%}
          <div class="kv-spot__feature{% if block.settings.layout == 'reverse' %} kv-spot__feature--reverse{% endif %}" {{ block.shopify_attributes }}>
            <div class="kv-spot__feature-media">
              {%- if block.settings.video_url != blank -%}
                <video src="{{ block.settings.video_url }}" autoplay muted loop playsinline></video>
              {%- elsif block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="kv-spot__feature-copy">
              {%- if block.settings.eyebrow != blank -%}
                <p class="kv-spot__feature-eyebrow">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h2 class="kv-spot__feature-title">{{ block.settings.title }}</h2>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="kv-spot__feature-text">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          </div>

        {%- when 'spec_table' -%}
          <div class="kv-spot__specs" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="kv-spot__specs-title">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <table class="kv-spot__specs-table">
              <tbody>
                {%- assign rows = block.settings.rows | newline_to_br | split: '<br />' -%}
                {%- for row in rows -%}
                  {%- assign row_clean = row | strip -%}
                  {%- if row_clean != blank -%}
                    <tr>
                      {%- assign cells = row_clean | split: '|' -%}
                      {%- for cell in cells -%}
                        <td>{{ cell | strip }}</td>
                      {%- endfor -%}
                    </tr>
                  {%- endif -%}
                {%- endfor -%}
              </tbody>
            </table>
          </div>

        {%- when 'gallery' -%}
          <div class="kv-spot__gallery" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="kv-spot__gallery-title">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="kv-spot__gallery-grid">
              {%- for i in (1..6) -%}
                {%- assign img_key = 'image_' | append: i -%}
                {%- assign img = block.settings[img_key] -%}
                {%- if img != blank -%}
                  <img src="{{ img | image_url: width: 800 }}" alt="" loading="lazy">
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>

        {%- when 'banner' -%}
          <div class="kv-spot__banner"
               {{ block.shopify_attributes }}
               {%- if block.settings.background_image != blank -%}
                 style="background-image:url('{{ block.settings.background_image | image_url: width: 1800 }}');"
               {%- endif -%}>
            <div class="kv-spot__banner-overlay"></div>
            <div class="kv-spot__banner-inner">
              {%- if block.settings.eyebrow != blank -%}
                <p class="kv-spot__banner-eyebrow">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="kv-spot__banner-title">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="kv-spot__banner-text">{{ block.settings.text }}</p>
              {%- endif -%}
              {%- if block.settings.btn_label != blank -%}
                <a href="{{ block.settings.btn_url }}" class="kayva-btn kayva-btn--ghost">{{ block.settings.btn_label }}</a>
              {%- endif -%}
            </div>
          </div>

        {%- when 'spacer' -%}
          <div style="height: {{ block.settings.height }}px;" {{ block.shopify_attributes }}></div>

      {%- endcase -%}
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "KAYVA Product Spotlight",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature (image + text)",
      "settings": [
        {
          "type": "select",
          "id": "layout",
          "label": "Layout",
          "options": [
            { "value": "default", "label": "Image left, text right" },
            { "value": "reverse", "label": "Image right, text left" }
          ],
          "default": "default"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (optional, overrides image)",
          "info": "Direct .mp4 URL — autoplays muted and looped, like Govee feature reels."
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "spec_table",
      "name": "Spec table",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Specifications"
        },
        {
          "type": "textarea",
          "id": "rows",
          "label": "Rows (one per line, label | value)",
          "default": "Light source | Dotless COB LED strip\nColour rendering | Ra95+\nVoltage | 24V DC\nPower draw | 12W per metre\nColour temperature | 2700K / 4000K\nLifespan | 30,000 hours",
          "info": "One spec per line. Separate label and value with |"
        }
      ]
    },
    {
      "type": "gallery",
      "name": "Gallery grid",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "In the home"
        },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" },
        { "type": "image_picker", "id": "image_4", "label": "Image 4" },
        { "type": "image_picker", "id": "image_5", "label": "Image 5" },
        { "type": "image_picker", "id": "image_6", "label": "Image 6" }
      ]
    },
    {
      "type": "banner",
      "name": "Full-width banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background image"
        },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "text", "label": "Text" },
        { "type": "text", "id": "btn_label", "label": "Button label" },
        { "type": "url", "id": "btn_url", "label": "Button URL" }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        {
          "type": "range",
          "id": "height",
          "label": "Height (px)",
          "min": 8,
          "max": 120,
          "step": 8,
          "default": 40
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KAYVA Product Spotlight",
      "settings": { "background_color": "#FFFFFF" },
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "layout": "default",
            "eyebrow": "DOTLESS DESIGN",
            "title": "No dots. No glare. Just light.",
            "text": "<p>KAYVA's COB construction spreads light evenly across the entire strip — no visible diodes, no hot spots, no shadow lines. The result is a clean wash of light that looks intentional, not improvised.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "layout": "reverse",
            "eyebrow": "COLOUR ACCURACY",
            "title": "Ra95+ rendering, true to life.",
            "text": "<p>Most strip lights sit around Ra80. KAYVA runs at Ra95+, which means skin tones, fabrics, and finishes look the way they actually do — not washed out or shifted cool.</p>"
          }
        },
        {
          "type": "spec_table",
          "settings": {
            "heading": "Specifications",
            "rows": "Light source | Dotless COB LED strip\nColour rendering | Ra95+\nVoltage | 24V DC\nPower draw | 12W per metre\nColour temperature | 2700K / 4000K\nLifespan | 30,000 hours"
          }
        },
        {
          "type": "banner",
          "settings": {
            "eyebrow": "DESIGNED FOR SINGAPORE HOMES",
            "heading": "Properly specified. Fairly priced.",
            "text": "Every KAYVA product is chosen for how it actually performs in the spaces we live in — not just on a spec sheet.",
            "btn_label": "Shop the range",
            "btn_url": "/collections/all"
          }
        }
      ]
    }
  ]
}
{% endschema %}
