<style>
  .site-header {
    background: {{ section.settings.background_color }};
    border-bottom-color: {{ section.settings.border_color }};
  }
  .site-header .site-header__logo,
  .site-header .site-nav__link,
  .site-header .header-icon {
    color: {{ section.settings.text_color }};
  }
  .site-header .menu-toggle__line {
    background: {{ section.settings.text_color }};
  }
  .site-header .site-nav__link:hover,
  .site-header .header-icon:hover {
    color: {{ section.settings.hover_color }};
  }
  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(61,42,21,0.08);
  }
  {%- if section.settings.transparent_on_hero and template.name == 'index' -%}
  .site-header--transparent {
    background: transparent !important;
    border-bottom-color: transparent !important;
    position: absolute;
    width: 100%;
  }
  .site-header--transparent .site-header__logo,
  .site-header--transparent .site-nav__link,
  .site-header--transparent .header-icon {
    color: {{ section.settings.transparent_text_color }};
  }
  .site-header--transparent .menu-toggle__line {
    background: {{ section.settings.transparent_text_color }};
  }
  {%- endif -%}
</style>

<header class="site-header{%- if section.settings.transparent_on_hero and template.name == 'index' %} site-header--transparent{%- endif -%}"
        role="banner">
  <div class="site-header__inner">

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 160 }}"
             alt="{{ shop.name }}"
             width="{{ section.settings.logo_width }}"
             loading="eager">
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <!-- Desktop Navigation -->
    <nav class="site-nav" aria-label="Main navigation">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}"
           class="site-nav__link{% if link.active %} site-nav__link--active{% endif %}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <!-- Actions -->
    <div class="site-header__actions">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="header-icon" aria-label="Search">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="8.5" cy="8.5" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
           class="header-icon" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 18c0-3.314 3.134-6 7-6s7 2.686 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
      {%- endif -%}

      <button class="header-icon cart-count" data-cart-open aria-label="Open cart">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M2 2h2l2.5 10h9l2-7H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8.5" cy="15.5" r="1.5" fill="currentColor"/>
          <circle cx="14.5" cy="15.5" r="1.5" fill="currentColor"/>
        </svg>
        <span class="cart-count__badge" style="display:none;">0</span>
      </button>

      <!-- Mobile toggle -->
      <button class="menu-toggle" aria-label="Open menu" aria-expanded="false">
        <span class="menu-toggle__line"></span>
        <span class="menu-toggle__line"></span>
        <span class="menu-toggle__line"></span>
      </button>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Leave blank to use shop name as text."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 80,
      "max": 240,
      "step": 10,
      "default": 120
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Header background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & icon colour",
      "default": "#1F1B16"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Hover colour",
      "default": "#B8753A"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bottom border colour",
      "default": "#E8E0D2"
    },
    {
      "type": "header",
      "content": "Transparent header (Homepage only)"
    },
    {
      "type": "checkbox",
      "id": "transparent_on_hero",
      "label": "Transparent on homepage hero",
      "default": false
    },
    {
      "type": "color",
      "id": "transparent_text_color",
      "label": "Transparent header text colour",
      "default": "#F5EFE5"
    }
  ]
}
{% endschema %}
