<style>
  .pillars {
    background: {{ section.settings.background_color }};
  }
  .pillars__heading-block {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .pillars__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }
  .pillar {
    padding: 40px 32px;
    border: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .pillar__number {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-amber);
  }
  .pillar__title {
    font-weight: 600;
    font-size: 17px;
    color: var(--color-dark-brown);
    line-height: 1.3;
  }
  .pillar__text {
    font-size: 14px;
    color: var(--color-ink);
    line-height: 1.7;
    flex: 1;
  }
  .pillar__link {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-warm-brown);
    border-bottom: 1px solid currentColor;
    align-self: flex-start;
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .pillar__link:hover { color: var(--color-amber); }

  @media (max-width: 768px) {
    .pillars__grid { grid-template-columns: 1fr; }
  }
</style>

<section class="pillars section" id="section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="pillars__heading-block">
        {%- if section.settings.subheading != blank -%}
          <p class="label" style="margin-bottom:12px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="pillars__grid">
      {%- for block in section.blocks -%}
        <div class="pillar" {{ block.shopify_attributes }}>
          <span class="pillar__number">0{{ forloop.index }}</span>
          <h3 class="pillar__title">{{ block.settings.title }}</h3>
          <p class="pillar__text">{{ block.settings.text }}</p>
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link_url }}" class="pillar__link">{{ block.settings.link_label }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Brand Pillars",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow label",
      "default": "Why KAYVA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Built on three principles."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards (px)",
      "min": 0,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Properly Specified"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "We publish the real numbers — CRI, R9, CCT tolerance, lumens. No hidden specs, no vague claims."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Pillars",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Properly Specified",
            "text": "We publish the real numbers — CRI, R9, CCT tolerance, lumens. No hidden specs, no vague claims."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Designed for Singapore",
            "text": "Built for tropical homes, HDB and condo proportions, and how Singapore rooms actually use light."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Ra95+ Throughout",
            "text": "One quality standard across every product — strip, GU10, and E27. The same colour accuracy chosen by museums."
          }
        }
      ]
    }
  ]
}
{% endschema %}
