{{ 'kayva.css' | asset_url | stylesheet_tag }}
<style>
.kv-pillars-grid{display:grid;grid-template-columns:repeat({{section.settings.columns}},1fr);gap:{{section.settings.gap}}px;}
.kv-pillar{padding:36px 28px;border:1px solid var(--kayva-line);display:flex;flex-direction:column;gap:14px;}
.kv-pillar__num{font-family:var(--kayva-font);font-size:11px;font-weight:500;letter-spacing:.18em;color:var(--kayva-amber);}
.kv-pillar__title{font-family:var(--kayva-font);font-weight:600;font-size:16px;color:var(--kayva-dark-brown);line-height:1.3;}
.kv-pillar__text{font-family:var(--kayva-font);font-size:13px;color:var(--kayva-ink);line-height:1.7;opacity:.85;flex:1;}
.kv-pillar__link{font-family:var(--kayva-font);font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--kayva-warm-brown);border-bottom:1px solid currentColor;align-self:flex-start;padding-bottom:2px;text-decoration:none;}
@media(max-width:768px){.kv-pillars-grid{grid-template-columns:1fr;}}
</style>

<section style="background:{{section.settings.bg}};padding:80px 0;">
  <div class="kayva-page-width">
    {%- if section.settings.heading != blank -%}
      <div style="text-align:center;margin-bottom:48px;">
        {%- if section.settings.eyebrow != blank -%}<span class="kayva-eyebrow" style="display:block;margin-bottom:8px;">{{section.settings.eyebrow}}</span>{%- endif -%}
        <h2 class="kayva-heading">{{section.settings.heading}}</h2>
      </div>
    {%- endif -%}
    <div class="kv-pillars-grid">
      {%- for block in section.blocks -%}
        <div class="kv-pillar" {{block.shopify_attributes}}>
          <span class="kv-pillar__num">0{{forloop.index}}</span>
          <h3 class="kv-pillar__title">{{block.settings.title}}</h3>
          <p class="kv-pillar__text">{{block.settings.text}}</p>
          {%- if block.settings.link_label != blank -%}
            <a href="{{block.settings.link_url}}" class="kv-pillar__link">{{block.settings.link_label}}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{"name":"KAYVA Brand Pillars","max_blocks":6,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Why KAYVA"},
{"type":"text","id":"heading","label":"Heading","default":"Built on three principles."},
{"type":"color","id":"bg","label":"Background","default":"#FFFFFF"},
{"type":"range","id":"columns","label":"Columns","min":2,"max":4,"step":1,"default":3},
{"type":"range","id":"gap","label":"Gap (px)","min":0,"max":48,"step":4,"default":24}
],"blocks":[{"type":"pillar","name":"Pillar","settings":[
{"type":"text","id":"title","label":"Title","default":"Properly Specified"},
{"type":"textarea","id":"text","label":"Text","default":"We publish the real numbers — CRI, R9, CCT tolerance, lumens."},
{"type":"text","id":"link_label","label":"Link label"},
{"type":"url","id":"link_url","label":"Link URL"}
]}],"presets":[{"name":"KAYVA Brand Pillars","blocks":[
{"type":"pillar","settings":{"title":"Properly Specified","text":"We publish the real numbers — CRI, R9, CCT tolerance, lumens. No hidden specs, no vague claims."}},
{"type":"pillar","settings":{"title":"Designed for Singapore","text":"Built for tropical homes, HDB and condo proportions, and how Singapore rooms actually use light."}},
{"type":"pillar","settings":{"title":"Ra95+ Throughout","text":"One quality standard across every product — strip, GU10, and E27. Museum-grade colour accuracy."}}
]}]}
{% endschema %}
