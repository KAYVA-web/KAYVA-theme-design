{{ 'kayva.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product = section.settings.product | default: product
  assign current_variant = product.selected_or_first_available_variant
-%}

<style>
.kv-pinfo-{{ section.id }} { font-family: var(--kayva-font); background: {{ section.settings.background_color }}; }
.kv-pinfo__wrap {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 64px;
  padding: 56px 0 80px;
  align-items: flex-start;
}
@media (max-width: 900px) {
  .kv-pinfo__wrap { grid-template-columns: 1fr; gap: 28px; padding: 32px 0 56px; }
}

/* Gallery */
.kv-pinfo__gallery { position: sticky; top: 24px; }
@media (max-width: 900px) { .kv-pinfo__gallery { position: static; } }
.kv-pinfo__main-image {
  aspect-ratio: 1 / 1;
  background: var(--kayva-cream, #F5EFE5);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 14px;
}
.kv-pinfo__main-image img { width: 100%; height: 100%; object-fit: contain; display: block; }
.kv-pinfo__thumbs { display: flex; gap: 10px; flex-wrap: wrap; }
.kv-pinfo__thumb {
  width: 76px;
  height: 76px;
  border-radius: 4px;
  overflow: hidden;
  background: var(--kayva-cream, #F5EFE5);
  border: 1.5px solid transparent;
  cursor: pointer;
  padding: 0;
}
.kv-pinfo__thumb.is-active { border-color: var(--kayva-dark-brown, #3D2A15); }
.kv-pinfo__thumb img { width: 100%; height: 100%; object-fit: contain; display: block; }

/* Copy column */
.kv-pinfo__eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--kayva-amber, #B8753A);
  margin-bottom: 12px;
}
.kv-pinfo__title {
  font-size: clamp(26px, 3.4vw, 38px);
  font-weight: 300;
  letter-spacing: -0.4px;
  line-height: 1.15;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 12px;
}
.kv-pinfo__price {
  font-size: 22px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 8px;
}
.kv-pinfo__price .kv-pinfo__price-compare {
  font-size: 16px;
  font-weight: 400;
  color: var(--kayva-soft-brown, #8A5524);
  text-decoration: line-through;
  margin-left: 10px;
}
/* Highlight bullets (Govee-style "key features" list) */
.kv-pinfo__highlights {
  list-style: none;
  margin: 0 0 32px;
  padding: 0;
  display: grid;
  gap: 12px;
}
.kv-pinfo__highlights li {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  font-size: 15px;
  line-height: 1.55;
  color: var(--kayva-warm-brown, #6B4823);
}
.kv-pinfo__highlights svg { flex-shrink: 0; margin-top: 3px; color: var(--kayva-amber, #B8753A); }
.kv-pinfo__highlights strong { color: var(--kayva-dark-brown, #3D2A15); font-weight: 600; }

/* Variant options */
.kv-pinfo__option { margin-bottom: 22px; }
.kv-pinfo__option-label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 10px;
}
.kv-pinfo__swatches { display: flex; flex-wrap: wrap; gap: 10px; }
.kv-pinfo__swatch {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 56px;
  height: 44px;
  padding: 0 16px;
  border: 1.5px solid var(--kayva-line, #E8E0D2);
  border-radius: 2px;
  background: var(--kayva-white, #FFFFFF);
  font-size: 14px;
  color: var(--kayva-dark-brown, #3D2A15);
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
}
.kv-pinfo__swatch input { position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none; }
.kv-pinfo__swatch:has(input:checked) {
  border-color: var(--kayva-dark-brown, #3D2A15);
  font-weight: 600;
}
.kv-pinfo__swatch:has(input:disabled) {
  opacity: 0.4;
  text-decoration: line-through;
  cursor: not-allowed;
}

/* Quantity + add to cart */
.kv-pinfo__buy-row { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 18px; flex-wrap: wrap; }
.kv-pinfo__qty-label {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--kayva-dark-brown, #3D2A15);
}
.kv-pinfo__qty {
  display: flex;
  align-items: stretch;
  border: 1.5px solid var(--kayva-line, #E8E0D2);
  border-radius: 2px;
  overflow: hidden;
  height: 50px;
}
.kv-pinfo__qty button {
  width: 40px;
  border: none;
  background: var(--kayva-cream, #F5EFE5);
  color: var(--kayva-dark-brown, #3D2A15);
  font-size: 18px;
  cursor: pointer;
}
.kv-pinfo__qty input {
  width: 48px;
  border: none;
  text-align: center;
  font-family: var(--kayva-font);
  font-size: 15px;
  color: var(--kayva-ink, #1F1B16);
  -moz-appearance: textfield;
}
.kv-pinfo__qty input::-webkit-outer-spin-button,
.kv-pinfo__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

.kv-pinfo__atc {
  flex: 1;
  min-width: 200px;
  height: 50px;
  border: none;
  border-radius: 2px;
  background: var(--kayva-dark-brown, #3D2A15);
  color: var(--kayva-cream, #F5EFE5);
  font-family: var(--kayva-font);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s;
}
.kv-pinfo__atc:hover { background: var(--kayva-warm-brown, #6B4823); }
.kv-pinfo__atc:disabled { background: var(--kayva-soft-brown, #8A5524); cursor: not-allowed; }

.kv-pinfo__note {
  font-size: 13px;
  color: var(--kayva-soft-brown, #8A5524);
  margin-bottom: 32px;
}

/* Bundle picker */
.kv-pinfo__bundles {
  border-top: 1px solid var(--kayva-line, #E8E0D2);
  border-bottom: 1px solid var(--kayva-line, #E8E0D2);
  padding: 24px 0 28px;
  margin-bottom: 28px;
}
.kv-pinfo__bundle-tabs { display: flex; gap: 28px; margin-bottom: 20px; }
.kv-pinfo__bundle-tab {
  border: none;
  background: none;
  padding: 0 0 10px;
  font-family: var(--kayva-font);
  font-size: 15px;
  font-weight: 600;
  color: var(--kayva-soft-brown, #8A5524);
  cursor: pointer;
  border-bottom: 2px solid transparent;
}
.kv-pinfo__bundle-tab.is-active {
  color: var(--kayva-dark-brown, #3D2A15);
  border-bottom-color: var(--kayva-dark-brown, #3D2A15);
}
.kv-pinfo__bundle-panel { display: none; }
.kv-pinfo__bundle-panel.is-active { display: block; }
.kv-pinfo__bundle-label {
  font-size: 13px;
  color: var(--kayva-soft-brown, #8A5524);
  margin-bottom: 14px;
}
.kv-pinfo__bundle-row {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--kayva-cream, #F5EFE5);
  border-radius: 4px;
  padding: 14px 16px;
}
.kv-pinfo__bundle-plus {
  text-align: center;
  font-size: 16px;
  color: var(--kayva-soft-brown, #8A5524);
  margin: 8px 0;
}
.kv-pinfo__bundle-thumb {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  border-radius: 4px;
  overflow: hidden;
  background: var(--kayva-white, #FFFFFF);
  display: block;
}
.kv-pinfo__bundle-thumb img { width: 100%; height: 100%; object-fit: contain; display: block; }
.kv-pinfo__bundle-info { flex: 1; min-width: 0; }
.kv-pinfo__bundle-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.kv-pinfo__bundle-price { font-size: 14px; color: var(--kayva-warm-brown, #6B4823); }
.kv-pinfo__bundle-select {
  border: 1.5px solid var(--kayva-line, #E8E0D2);
  border-radius: 2px;
  background: var(--kayva-white, #FFFFFF);
  font-family: var(--kayva-font);
  font-size: 13px;
  color: var(--kayva-ink, #1F1B16);
  padding: 8px 10px;
  max-width: 150px;
}
.kv-pinfo__bundle-total {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin: 18px 0 14px;
  font-size: 15px;
  color: var(--kayva-dark-brown, #3D2A15);
}
.kv-pinfo__bundle-total strong { font-size: 20px; }
.kv-pinfo__bundle-total s { color: var(--kayva-soft-brown, #8A5524); font-weight: 400; font-size: 14px; }
.kv-pinfo__bundle-add { width: 100%; }

/* Floating buy bar */
.kv-pinfo__floatbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  background: var(--kayva-white, #FFFFFF);
  border-top: 1px solid var(--kayva-line, #E8E0D2);
  box-shadow: 0 -6px 24px rgba(61,42,21,0.08);
}
.kv-pinfo__floatbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 14px 24px;
}
.kv-pinfo__floatbar-info { display: flex; align-items: center; gap: 14px; min-width: 0; }
.kv-pinfo__floatbar-info img {
  width: 48px;
  height: 48px;
  object-fit: contain;
  border-radius: 4px;
  background: var(--kayva-cream, #F5EFE5);
  flex-shrink: 0;
}
.kv-pinfo__floatbar-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280px;
}
.kv-pinfo__floatbar-price { font-size: 14px; color: var(--kayva-warm-brown, #6B4823); }
.kv-pinfo__floatbar-actions { display: flex; gap: 12px; flex-shrink: 0; }
.kv-pinfo__floatbar-btn {
  height: 44px;
  padding: 0 28px;
  border: 1.5px solid var(--kayva-dark-brown, #3D2A15);
  border-radius: 2px;
  background: var(--kayva-dark-brown, #3D2A15);
  color: var(--kayva-cream, #F5EFE5);
  font-family: var(--kayva-font);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.2s;
}
.kv-pinfo__floatbar-btn--ghost {
  background: transparent;
  color: var(--kayva-dark-brown, #3D2A15);
}
.kv-pinfo__floatbar-btn:disabled { opacity: 0.4; cursor: not-allowed; }
@media (max-width: 640px) {
  .kv-pinfo__floatbar-title { max-width: 140px; }
  .kv-pinfo__floatbar-btn { padding: 0 16px; }
}

/* Accordion (description / shipping / etc) */
.kv-pinfo__accordion { border-top: 1px solid var(--kayva-line, #E8E0D2); }
.kv-pinfo__accordion-item { border-bottom: 1px solid var(--kayva-line, #E8E0D2); }
.kv-pinfo__accordion-item summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 2px;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--kayva-dark-brown, #3D2A15);
  cursor: pointer;
  list-style: none;
}
.kv-pinfo__accordion-item summary::-webkit-details-marker { display: none; }
.kv-pinfo__accordion-item summary svg { transition: transform 0.2s; }
.kv-pinfo__accordion-item[open] summary svg { transform: rotate(180deg); }
.kv-pinfo__accordion-body {
  padding: 0 2px 20px;
  font-size: 15px;
  line-height: 1.7;
  color: var(--kayva-warm-brown, #6B4823);
}
.kv-pinfo__accordion-body p { margin-bottom: 12px; }

/* Description show more / show less */
.kv-pinfo__desc-body {
  max-height: 6.6em;
  overflow: hidden;
  position: relative;
  -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
          mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
}
.kv-pinfo__desc-body.is-expanded {
  max-height: none;
  -webkit-mask-image: none;
          mask-image: none;
}
.kv-pinfo__desc-toggle {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: none;
  background: none;
  padding: 6px 0 18px;
  font-family: var(--kayva-font);
  font-size: 13px;
  font-weight: 600;
  color: var(--kayva-amber, #B8753A);
  cursor: pointer;
}

/* Section nav (Govee-style sticky tab bar linking to spotlight blocks) */
.kv-pinfo__section-nav {
  display: flex;
  gap: 32px;
  border-top: 1px solid var(--kayva-line, #E8E0D2);
  border-bottom: 1px solid var(--kayva-line, #E8E0D2);
  padding: 16px 2px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.kv-pinfo__section-nav button {
  border: none;
  background: none;
  padding: 0;
  font-family: var(--kayva-font);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--kayva-warm-brown, #6B4823);
  cursor: pointer;
  transition: color 0.15s;
}
.kv-pinfo__section-nav button:hover { color: var(--kayva-dark-brown, #3D2A15); }
</style>

<div class="kv-pinfo-{{ section.id }}">
  <div class="kayva-page-width">
    <div class="kv-pinfo__wrap">

      <!-- Gallery -->
      <div class="kv-pinfo__gallery">
        <div class="kv-pinfo__main-image" id="kv-pinfo-main-{{ section.id }}">
          {%- if product.featured_media -%}
            <img src="{{ product.featured_media | image_url: width: 1200 }}" alt="{{ product.featured_media.alt | escape }}" id="kv-pinfo-main-img-{{ section.id }}">
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="kv-pinfo__thumbs">
            {%- for media in product.media limit: 8 -%}
              <button type="button" class="kv-pinfo__thumb{% if forloop.first %} is-active{% endif %}" data-full="{{ media | image_url: width: 1200 }}" onclick="
                document.getElementById('kv-pinfo-main-img-{{ section.id }}').src = this.dataset.full;
                this.parentElement.querySelectorAll('.kv-pinfo__thumb').forEach(function(t){t.classList.remove('is-active')});
                this.classList.add('is-active');
              ">
                <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | escape }}" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Copy / buy box -->
      <div class="kv-pinfo__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="kv-pinfo__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        <h1 class="kv-pinfo__title">{{ product.title }}</h1>

        <div class="kv-pinfo__price">
          {{ current_variant.price | money }}
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="kv-pinfo__price-compare">{{ current_variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <ul class="kv-pinfo__highlights">
            {%- for block in section.blocks -%}
              {%- if block.type == 'highlight' -%}
                <li {{ block.shopify_attributes }}>
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5l3.2 3.2L13 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>
                    {%- if block.settings.label != blank -%}<strong>{{ block.settings.label }}</strong> {%- endif -%}
                    {{ block.settings.text }}
                  </span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- form 'product', product, id: 'kv-pinfo-form', class: 'kv-pinfo__form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="kv-pinfo-variant-id-{{ section.id }}">

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="kv-pinfo__option">
                <span class="kv-pinfo__option-label">{{ option.name }}</span>
                <div class="kv-pinfo__swatches">
                  {%- for value in option.values -%}
                    <label class="kv-pinfo__swatch">
                      <input type="radio"
                             name="kv-option-{{ section.id }}-{{ option.position }}"
                             value="{{ value | escape }}"
                             {% if option.selected_value == value %}checked{% endif %}
                             onchange="kvPinfoSelectOption{{ section.id }}({{ option.position }}, this.value)">
                      {{ value }}
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <div class="kv-pinfo__buy-row">
            <span class="kv-pinfo__qty-label">Quantity</span>
            <div class="kv-pinfo__qty">
              <button type="button" onclick="var i=this.nextElementSibling;i.value=Math.max(1,(parseInt(i.value)||1)-1);">−</button>
              <input type="number" name="quantity" value="1" min="1">
              <button type="button" onclick="var i=this.previousElementSibling;i.value=(parseInt(i.value)||1)+1;">+</button>
            </div>
          </div>
        {%- endform -%}

        <!-- Bundle picker (Govee-style: tabs + frequently-bought-together rows, adds as one cart action) -->
        {%- assign bundle_blocks = section.blocks | where: 'type', 'bundle_option' -%}
        {%- if bundle_blocks.size > 0 -%}
          <div class="kv-pinfo__bundles" id="kv-bundles-{{ section.id }}">
            <div class="kv-pinfo__bundle-tabs" role="tablist">
              {%- for block in bundle_blocks -%}
                <button type="button" class="kv-pinfo__bundle-tab{% if forloop.first %} is-active{% endif %}"
                        data-bundle-tab="{{ forloop.index0 }}">
                  {{ block.settings.label | default: 'Bundle' }}
                </button>
              {%- endfor -%}
            </div>

            {%- for block in bundle_blocks -%}
              {%- assign addon = block.settings.addon_product -%}
              {%- assign addon_variant = addon.selected_or_first_available_variant -%}
              <div class="kv-pinfo__bundle-panel{% if forloop.first %} is-active{% endif %}" data-bundle-panel="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                <p class="kv-pinfo__bundle-label">Frequently bought together:</p>

                <div class="kv-pinfo__bundle-row">
                  <div class="kv-pinfo__bundle-thumb">
                    {%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 160 }}" alt="{{ product.title | escape }}" loading="lazy">{%- endif -%}
                  </div>
                  <div class="kv-pinfo__bundle-info">
                    <p class="kv-pinfo__bundle-name">{{ product.title }}</p>
                    <p class="kv-pinfo__bundle-price" data-bundle-main-price="{{ forloop.index0 }}">{{ current_variant.price | money }}</p>
                  </div>
                  {%- unless product.has_only_default_variant -%}
                    <select class="kv-pinfo__bundle-select" data-bundle-main-select="{{ forloop.index0 }}">
                      {%- for v in product.variants -%}
                        <option value="{{ v.id }}" data-price="{{ v.price }}" {% if v.id == current_variant.id %}selected{% endif %}>{{ v.title }}</option>
                      {%- endfor -%}
                    </select>
                  {%- endunless -%}
                </div>

                {%- if addon != blank -%}
                  <div class="kv-pinfo__bundle-plus">+</div>
                  <div class="kv-pinfo__bundle-row">
                    <div class="kv-pinfo__bundle-thumb">
                      {%- if addon.featured_image -%}<img src="{{ addon.featured_image | image_url: width: 160 }}" alt="{{ addon.title | escape }}" loading="lazy">{%- endif -%}
                    </div>
                    <div class="kv-pinfo__bundle-info">
                      <p class="kv-pinfo__bundle-name">{{ addon.title }}</p>
                      <p class="kv-pinfo__bundle-price" data-bundle-addon-price="{{ forloop.index0 }}">{{ addon_variant.price | money }}</p>
                    </div>
                    {%- unless addon.has_only_default_variant -%}
                      <select class="kv-pinfo__bundle-select" data-bundle-addon-select="{{ forloop.index0 }}">
                        {%- for v in addon.variants -%}
                          <option value="{{ v.id }}" data-price="{{ v.price }}" {% if v.id == addon_variant.id %}selected{% endif %}>{{ v.title }}</option>
                        {%- endfor -%}
                      </select>
                    {%- endunless -%}
                  </div>
                {%- endif -%}

                <div class="kv-pinfo__bundle-total">
                  <span>Total:</span>
                  <strong data-bundle-total="{{ forloop.index0 }}"></strong>
                  {%- if block.settings.savings > 0 -%}
                    <s data-bundle-compare="{{ forloop.index0 }}"></s>
                  {%- endif -%}
                </div>

                <button type="button"
                        class="kv-pinfo__atc kv-pinfo__bundle-add"
                        data-bundle-add="{{ forloop.index0 }}"
                        data-main-variant-id="{{ current_variant.id }}"
                        data-main-price="{{ current_variant.price | default: 0 }}"
                        data-addon-variant-id="{{ addon_variant.id }}"
                        data-addon-price="{{ addon_variant.price | default: 0 }}"
                        data-savings="{{ block.settings.savings | default: 0 }}">
                  {{ block.settings.add_label | default: 'Add bundle to cart' }}
                </button>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.note != blank -%}
          <p class="kv-pinfo__note">{{ section.settings.note }}</p>
        {%- endif -%}

        <!-- Accordion -->
        <div class="kv-pinfo__accordion">
          {%- if product.description != blank -%}
            <details class="kv-pinfo__accordion-item" open>
              <summary>
                {{ section.settings.description_label | default: 'Description' }}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6.5l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
              </summary>
              <div class="kv-pinfo__accordion-body kv-pinfo__desc-body" data-desc-body>{{ product.description }}</div>
              <button type="button" class="kv-pinfo__desc-toggle" data-desc-toggle>Show more</button>
            </details>
          {%- endif -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'accordion' -%}
              <details class="kv-pinfo__accordion-item" {{ block.shopify_attributes }}>
                <summary>
                  {{ block.settings.title }}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6.5l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </summary>
                <div class="kv-pinfo__accordion-body">{{ block.settings.content }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>

      </div>
    </div>

    <!-- Section nav — smooth-scrolls down to matching blocks in the KAYVA Product Spotlight section -->
    <nav class="kv-pinfo__section-nav">
      <button type="button" data-scroll-to="feature">Description</button>
      <button type="button" data-scroll-to="spec_table">Specifications</button>
      <button type="button" data-scroll-to="gallery">Gallery</button>
    </nav>
  </div>

  <!-- Floating buy bar — appears once the main buy box scrolls out of view -->
  <div class="kv-pinfo__floatbar" id="kv-floatbar-{{ section.id }}">
    <div class="kayva-page-width kv-pinfo__floatbar-inner">
      <div class="kv-pinfo__floatbar-info">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}">
        {%- endif -%}
        <div>
          <p class="kv-pinfo__floatbar-title">{{ product.title }}</p>
          <p class="kv-pinfo__floatbar-price" id="kv-floatbar-price-{{ section.id }}">{{ current_variant.price | money }}</p>
        </div>
      </div>
      <div class="kv-pinfo__floatbar-actions">
        <button type="button" class="kv-pinfo__floatbar-btn kv-pinfo__floatbar-btn--ghost" id="kv-floatbar-add-{{ section.id }}">
          {{ section.settings.atc_label | default: 'Add to cart' }}
        </button>
        <button type="button" class="kv-pinfo__floatbar-btn" id="kv-floatbar-buy-{{ section.id }}">
          {{ section.settings.buy_now_label | default: 'Buy now' }}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function(){
    var product = {{ product | json }};
    var sectionId = {{ section.id | json }};
    var selected = {};
    {%- for option in product.options_with_values -%}
      selected[{{ option.position | json }}] = {{ option.selected_value | json }};
    {%- endfor -%}

    window['kvPinfoSelectOption' + sectionId] = function(position, value){
      selected[position] = value;
      var match = product.variants.find(function(v){
        return product.options_with_values.every(function(opt, i){
          var key = 'option' + (i + 1);
          return v[key] === selected[opt.position];
        });
      });
      var input = document.getElementById('kv-pinfo-variant-id-' + sectionId);
      if (match) {
        input.value = match.id;
        if (match.featured_media) {
          var img = document.getElementById('kv-pinfo-main-img-' + sectionId);
          if (img) { img.src = match.featured_media.preview_image.src + '&width=1200'; }
        }
      }
      syncFloatbar();
    };

    function moneyFmt(cents){
      return ({{ shop.money_format | json }}).replace(/\{\{\s*amount\s*\}\}/, (cents/100).toFixed(2));
    }

    /* ---------- Bundle picker ---------- */
    var bundleRoot = document.getElementById('kv-bundles-' + sectionId);
    if (bundleRoot) {
      var panels = bundleRoot.querySelectorAll('[data-bundle-panel]');
      var tabs = bundleRoot.querySelectorAll('[data-bundle-tab]');

      tabs.forEach(function(tab){
        tab.addEventListener('click', function(){
          var index = tab.dataset.bundleTab;
          tabs.forEach(function(t){ t.classList.toggle('is-active', t === tab); });
          panels.forEach(function(p){ p.classList.toggle('is-active', p.dataset.bundlePanel === index); });
        });
      });

      function recalcBundle(panel){
        var idx = panel.dataset.bundlePanel;
        var mainSelect = panel.querySelector('[data-bundle-main-select]');
        var addonSelect = panel.querySelector('[data-bundle-addon-select]');
        var addBtn = panel.querySelector('[data-bundle-add]');
        var mainPriceEl = panel.querySelector('[data-bundle-main-price="' + idx + '"]');
        var addonPriceEl = panel.querySelector('[data-bundle-addon-price="' + idx + '"]');
        var totalEl = panel.querySelector('[data-bundle-total="' + idx + '"]');
        var compareEl = panel.querySelector('[data-bundle-compare="' + idx + '"]');

        var mainPrice = parseInt(addBtn.dataset.mainPrice || '0', 10);
        if (mainSelect) {
          mainPrice = parseInt(mainSelect.options[mainSelect.selectedIndex].dataset.price, 10);
          if (mainPriceEl) { mainPriceEl.textContent = moneyFmt(mainPrice); }
          addBtn.dataset.mainVariantId = mainSelect.value;
        }

        var addonPrice = parseInt(addBtn.dataset.addonPrice || '0', 10);
        if (addonSelect) {
          addonPrice = parseInt(addonSelect.options[addonSelect.selectedIndex].dataset.price, 10);
          if (addonPriceEl) { addonPriceEl.textContent = moneyFmt(addonPrice); }
          addBtn.dataset.addonVariantId = addonSelect.value;
        }

        var savings = parseFloat(addBtn.dataset.savings || '0') * 100;
        var rawTotal = mainPrice + addonPrice;
        var total = Math.max(rawTotal - savings, 0);
        if (totalEl) { totalEl.textContent = moneyFmt(total); }
        if (compareEl) { compareEl.textContent = savings > 0 ? moneyFmt(rawTotal) : ''; }
      }

      panels.forEach(function(panel){
        recalcBundle(panel);
        panel.querySelectorAll('select').forEach(function(sel){
          sel.addEventListener('change', function(){ recalcBundle(panel); });
        });
        var addBtn = panel.querySelector('[data-bundle-add]');
        if (addBtn) {
          addBtn.addEventListener('click', function(){
            var items = [];
            if (addBtn.dataset.mainVariantId) { items.push({ id: parseInt(addBtn.dataset.mainVariantId, 10), quantity: 1 }); }
            if (addBtn.dataset.addonVariantId) { items.push({ id: parseInt(addBtn.dataset.addonVariantId, 10), quantity: 1 }); }
            if (!items.length) { return; }
            addBtn.disabled = true;
            var original = addBtn.textContent;
            addBtn.textContent = 'Adding…';
            fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ items: items })
            }).then(function(r){ return r.json(); }).then(function(){
              window.location.href = '/cart';
            }).catch(function(){
              addBtn.disabled = false;
              addBtn.textContent = original;
            });
          });
        }
      });
    }

    /* ---------- Floating buy bar ---------- */
    var floatbar = document.getElementById('kv-floatbar-' + sectionId);
    var floatPriceEl = document.getElementById('kv-floatbar-price-' + sectionId);
    var floatAddBtn = document.getElementById('kv-floatbar-add-' + sectionId);
    var floatBuyBtn = document.getElementById('kv-floatbar-buy-' + sectionId);
    var mainForm = document.getElementById('kv-pinfo-form');
    var mainVariantInput = document.getElementById('kv-pinfo-variant-id-' + sectionId);
    var mainQtyInput = mainForm ? mainForm.querySelector('input[name="quantity"]') : null;

    function syncFloatbar(){
      if (!floatPriceEl || !mainVariantInput) { return; }
      var match = product.variants.find(function(v){ return v.id == mainVariantInput.value; });
      if (match) { floatPriceEl.textContent = moneyFmt(match.price); }
      var unavailable = match ? !match.available : false;
      if (floatAddBtn) { floatAddBtn.disabled = unavailable; }
      if (floatBuyBtn) { floatBuyBtn.disabled = unavailable; }
    }

    function floatbarAddToCart(buyNow){
      if (!mainVariantInput) { return; }
      var qty = mainQtyInput ? (parseInt(mainQtyInput.value, 10) || 1) : 1;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(mainVariantInput.value, 10), quantity: qty }] })
      }).then(function(r){ return r.json(); }).then(function(){
        window.location.href = buyNow ? '/checkout' : '/cart';
      });
    }

    if (floatAddBtn) { floatAddBtn.addEventListener('click', function(){ floatbarAddToCart(false); }); }
    if (floatBuyBtn) { floatBuyBtn.addEventListener('click', function(){ floatbarAddToCart(true); }); }

    /* Floating bar is permanently fixed to the bottom — reserve space so it never overlaps content */
    if (floatbar) {
      document.body.style.paddingBottom = floatbar.offsetHeight + 'px';
    }

    syncFloatbar();

    /* ---------- Description: show more / show less ---------- */
    var descBody = document.querySelector('.kv-pinfo-' + sectionId + ' [data-desc-body]');
    var descToggle = document.querySelector('.kv-pinfo-' + sectionId + ' [data-desc-toggle]');
    if (descBody && descToggle) {
      descToggle.addEventListener('click', function(){
        var expanded = descBody.classList.toggle('is-expanded');
        descToggle.textContent = expanded
          ? {{ 'Show less' | json }}
          : {{ 'Show more' | json }};
      });
    }

    /* ---------- Section nav: smooth-scroll to blocks in the spotlight section ---------- */
    document.querySelectorAll('.kv-pinfo-' + sectionId + ' [data-scroll-to]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var target = document.querySelector('[data-spot-block="' + btn.dataset.scrollTo + '"]');
        if (target) { target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
    });
  })();
</script>

