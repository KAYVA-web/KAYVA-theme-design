      "name": "Accordion item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shipping & returns" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    }
  ],
  "presets": [
    {
      "name": "KAYVA Product Info",
      "settings": {
        "background_color": "#FFFFFF",
        "eyebrow": "STRIP LIGHTING · RA95+",
        "atc_label": "Add to cart",
        "sold_out_label": "Sold out",
        "buy_now_label": "Buy now",
        "note": "Ships within 2–4 working days. Free delivery on orders over $150.",
        "description_label": "Description"
      },
      "blocks": [
        { "type": "bundle_option", "settings": { "label": "Bundle 1", "savings": 0, "add_label": "Add bundle to cart" } },
        { "type": "bundle_option", "settings": { "label": "Bundle 2", "savings": 15, "add_label": "Add bundle to cart" } },
        { "type": "bundle_option", "settings": { "label": "Bundle 3", "savings": 25, "add_label": "Add bundle to cart" } },
        { "type": "highlight", "settings": { "label": "Ra95+:", "text": "True-to-life colour rendering, indoors and out." } },
        { "type": "highlight", "settings": { "label": "Dotless COB:", "text": "Even, shadow-free light with no visible diodes." } },
        { "type": "highlight", "settings": { "label": "30,000 hrs:", "text": "Rated lifespan with stable brightness and colour." } },
        { "type": "accordion", "settings": { "title": "Shipping & returns", "content": "<p>Delivered within 2–4 working days across Singapore. 30-day returns on unused items in original packaging.</p>" } },
        { "type": "accordion", "settings": { "title": "Warranty", "content": "<p>2-year manufacturer warranty covering defects in materials and workmanship.</p>" } }
      ]
    }
  ]
}
