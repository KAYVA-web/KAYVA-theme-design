<section class="section">
  <div class="page-width--narrow">
    <nav class="breadcrumbs" style="margin-bottom:var(--spacing-lg);">
      <a href="/">Home</a><span class="breadcrumbs__sep">/</span>
      <a href="{{ blog.url }}">{{ blog.title }}</a><span class="breadcrumbs__sep">/</span>
      <span>{{ article.title }}</span>
    </nav>
    <p style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-amber); margin-bottom:12px;">{{ article.published_at | date: '%d %B %Y' }}</p>
    <h1 style="font-size:clamp(24px,3.5vw,40px); font-weight:300; color:var(--color-dark-brown); line-height:1.15; margin-bottom:var(--spacing-lg);">{{ article.title }}</h1>
    {%- if article.image -%}
      <div style="margin-bottom:var(--spacing-lg); overflow:hidden;">
        <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | escape }}" style="width:100%; height:auto;" loading="lazy">
      </div>
    {%- endif -%}
    <div style="font-size:16px; line-height:1.8; color:var(--color-ink);">{{ article.content }}</div>
  </div>
</section>
{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
