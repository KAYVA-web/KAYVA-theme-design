<section class="section">
  <div class="page-width">
    <h1 class="section-heading" style="margin-bottom:var(--spacing-xl);">{{ blog.title }}</h1>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:var(--grid-gutter);">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" style="display:flex; flex-direction:column; gap:12px; text-decoration:none;">
          {%- if article.image -%}
            <div style="aspect-ratio:3/2; overflow:hidden; background:var(--color-cream);">
              <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" style="width:100%; height:100%; object-fit:cover;" loading="lazy">
            </div>
          {%- endif -%}
          <p style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-amber);">{{ article.published_at | date: '%d %B %Y' }}</p>
          <h2 style="font-size:16px; font-weight:600; color:var(--color-dark-brown); line-height:1.3;">{{ article.title }}</h2>
          <p style="font-size:13px; color:var(--color-soft-brown); line-height:1.6;">{{ article.excerpt | strip_html | truncatewords: 20 }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{ "name": "Blog Posts", "settings": [] }
{% endschema %}
