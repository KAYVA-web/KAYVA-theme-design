<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__grid">

      <!-- Brand Column -->
      <div class="footer-brand">
        <div class="footer-brand__logo">{{ shop.name }}</div>
        <p class="footer-brand__tagline">{{ section.settings.tagline }}</p>

        {%- if section.settings.show_social -%}
          <div style="display:flex; gap:16px; margin-top:24px;">
            {%- if settings.instagram_url != blank -%}
              <a href="{{ settings.instagram_url }}" aria-label="Instagram" style="color:rgba(245,239,229,0.6);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.facebook_url != blank -%}
              <a href="{{ settings.facebook_url }}" aria-label="Facebook" style="color:rgba(245,239,229,0.6);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Menu columns -->
      {%- for i in (1..3) -%}
        {%- assign menu_key = 'footer_menu_' | append: i -%}
        {%- assign title_key = 'footer_title_' | append: i -%}
        {%- assign menu_handle = section.settings[menu_key] -%}
        {%- if linklists[menu_handle].links.size > 0 -%}
          <div class="footer-col">
            <p class="footer-col__title">{{ section.settings[title_key] }}</p>
            <ul class="footer-col__links">
              {%- for link in linklists[menu_handle].links -%}
                <li><a href="{{ link.url }}" class="footer-col__link">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Designed in Singapore.</span>
      <div style="display:flex; gap:16px;">
        {%- if linklists['footer-legal'].links.size > 0 -%}
          {%- for link in linklists['footer-legal'].links -%}
            <a href="{{ link.url }}" style="color:rgba(245,239,229,0.4); transition:color 0.2s;" onmouseover="this.style.color='rgba(245,239,229,0.8)'" onmouseout="this.style.color='rgba(245,239,229,0.4)'">{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Ra95+ lighting, properly specified, designed for Singapore homes."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "text",
      "id": "footer_title_1",
      "label": "Column 1 title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "Column 1 menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "text",
      "id": "footer_title_2",
      "label": "Column 2 title",
      "default": "Learn"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "Column 2 menu"
    },
    {
      "type": "header",
      "content": "Column 3"
    },
    {
      "type": "text",
      "id": "footer_title_3",
      "label": "Column 3 title",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "footer_menu_3",
      "label": "Column 3 menu"
    }
  ]
}
{% endschema %}
