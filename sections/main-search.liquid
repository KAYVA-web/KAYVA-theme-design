<section class="section">
  <div class="page-width">
    <div style="max-width:560px; margin:0 auto var(--spacing-xl);">
      <h1 class="section-heading" style="margin-bottom:var(--spacing-md); text-align:center;">Search</h1>
      <form action="{{ routes.search_url }}" method="get" role="search">
        <div style="display:flex; gap:0;">
          <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products…"
                 style="flex:1; padding:14px 18px; border:1.5px solid var(--color-line); border-right:none; font-size:14px; outline:none; font-family:inherit;">
          <button type="submit" class="btn btn--primary" style="border-radius:0;">Search</button>
        </div>
        <input type="hidden" name="type" value="product">
      </form>
    </div>
    {%- if search.performed -%}
      <p style="font-size:13px; color:var(--color-soft-brown); margin-bottom:var(--spacing-lg);">
        {{ search.results_count }} result{{ search.results_count | pluralize: '', 's' }} for &ldquo;{{ search.terms | escape }}&rdquo;
      </p>
      {%- if search.results_count > 0 -%}
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:var(--grid-gutter);">
          {%- for result in search.results -%}
            {%- if result.object_type == 'product' -%}
              {%- render 'product-card', product: result -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="font-size:15px; color:var(--color-soft-brown); text-align:center;">No products found. Try a different search term.</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Search Results", "settings": [] }
{% endschema %}
