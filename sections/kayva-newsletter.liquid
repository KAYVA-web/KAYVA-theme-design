{{ 'kayva.css' | asset_url | stylesheet_tag }}
<style>
.kv-newsletter-inner{max-width:560px;margin:0 auto;text-align:center;display:flex;flex-direction:column;align-items:center;gap:18px;}
.kv-newsletter-form{display:flex;width:100%;max-width:420px;}
.kv-newsletter-input{flex:1;padding:13px 16px;border:1.5px solid {{section.settings.border_color}};border-right:none;font-family:var(--kayva-font);font-size:14px;color:{{section.settings.text_color}};background:transparent;outline:none;border-radius:0;}
.kv-newsletter-input::placeholder{opacity:.5;color:{{section.settings.text_color}};}
.kv-newsletter-submit{padding:13px 20px;background:{{section.settings.btn_bg}};color:{{section.settings.btn_text}};font-family:var(--kayva-font);font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;border:1.5px solid {{section.settings.btn_bg}};cursor:pointer;border-radius:0;}
@media(max-width:480px){.kv-newsletter-form{flex-direction:column;}.kv-newsletter-input{border-right:1.5px solid {{section.settings.border_color}};}}
</style>

<section style="background:{{section.settings.bg}};padding:80px 0;">
  <div class="kayva-page-width">
    <div class="kv-newsletter-inner">
      {%- if section.settings.eyebrow != blank -%}
        <span style="font-family:var(--kayva-font);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:{{section.settings.text_color}};opacity:.6;">{{section.settings.eyebrow}}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 style="font-family:var(--kayva-font);font-weight:600;font-size:clamp(18px,2.5vw,24px);color:{{section.settings.text_color}};">{{section.settings.heading}}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p style="font-family:var(--kayva-font);font-size:14px;color:{{section.settings.text_color}};opacity:.7;line-height:1.65;">{{section.settings.subtext}}</p>
      {%- endif -%}
      {%- form 'customer', id: 'kv-newsletter-{{section.id}}', data-newsletter-form: '' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="kv-newsletter-form">
          <input class="kv-newsletter-input" type="email" name="contact[email]" placeholder="{{section.settings.placeholder}}" autocomplete="email" required>
          <button class="kv-newsletter-submit" type="submit">{{section.settings.btn_label}}</button>
        </div>
      {%- endform -%}
      <p style="font-family:var(--kayva-font);font-size:11px;color:{{section.settings.text_color}};opacity:.45;">{{section.settings.disclaimer}}</p>
    </div>
  </div>
</section>

{% schema %}
{"name":"KAYVA Newsletter","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Lighting guides"},
{"type":"text","id":"heading","label":"Heading","default":"Get our Singapore lighting guide."},
{"type":"text","id":"subtext","label":"Subtext","default":"CRI explained, Kelvin guide, and cove lighting tips for HDB and condo spaces."},
{"type":"text","id":"placeholder","label":"Placeholder","default":"your@email.com"},
{"type":"text","id":"btn_label","label":"Button","default":"Subscribe"},
{"type":"text","id":"disclaimer","label":"Disclaimer","default":"No spam. Unsubscribe any time."},
{"type":"color","id":"bg","label":"Background","default":"#F5EFE5"},
{"type":"color","id":"text_color","label":"Text","default":"#3D2A15"},
{"type":"color","id":"border_color","label":"Input border","default":"#8A5524"},
{"type":"color","id":"btn_bg","label":"Button background","default":"#3D2A15"},
{"type":"color","id":"btn_text","label":"Button text","default":"#F5EFE5"}
],"presets":[{"name":"KAYVA Newsletter"}]}
{% endschema %}
