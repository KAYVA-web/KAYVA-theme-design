<section class="section">
  <div class="page-width">
    <h1 class="section-heading" style="margin-bottom:var(--spacing-xl);">All Collections</h1>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:var(--grid-gutter);">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" style="display:flex; flex-direction:column; gap:12px; text-decoration:none;">
          <div style="aspect-ratio:4/3; overflow:hidden; background:var(--color-cream);">
            {%- if collection.image -%}
              <img src="{{ collection.image | image_url: width: 600 }}"
                   alt="{{ collection.image.alt | escape }}"
                   style="width:100%; height:100%; object-fit:cover;"
                   loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <h2 style="font-size:15px; font-weight:600; color:var(--color-dark-brown);">{{ collection.title }}</h2>
          <p style="font-size:12px; color:var(--color-soft-brown);">{{ collection.products_count }} products</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collection List", "settings": [] }
{% endschema %}
