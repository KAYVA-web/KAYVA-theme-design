{{ 'kayva.css' | asset_url | stylesheet_tag }}
<style>
.kv-col-grid{display:grid;grid-template-columns:repeat({{section.settings.columns}},1fr);gap:{{section.settings.gap}}px;}
.kv-col-tile__icon{width:{{section.settings.icon_size}}px;height:{{section.settings.icon_size}}px;border-radius:{{section.settings.icon_size | divided_by:4}}px;}
@media(max-width:768px){.kv-col-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:420px){.kv-col-grid{grid-template-columns:repeat(2,1fr);}}
</style>

<section style="background:{{section.settings.bg}};padding:80px 0;" id="kv-colshowcase-{{section.id}}">
  <div class="kayva-page-width">
    {%- if section.settings.heading != blank -%}
      <div style="text-align:{{section.settings.text_align}};margin-bottom:40px;">
        {%- if section.settings.eyebrow != blank -%}<span class="kayva-eyebrow" style="display:block;margin-bottom:8px;">{{section.settings.eyebrow}}</span>{%- endif -%}
        <h2 class="kayva-heading">{{section.settings.heading}}</h2>
      </div>
    {%- endif -%}

    <div class="kv-col-grid">
      {%- for block in section.blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        <a href="{{col.url | default: block.settings.url | default:'#'}}" class="kayva-collection-tile" {{block.shopify_attributes}} style="border-radius:{{section.settings.radius}}px;">
          <div class="kayva-collection-tile__icon kv-col-tile__icon" style="overflow:hidden;">
            {%- if block.settings.image != blank -%}
              <img src="{{block.settings.image | image_url: width:300}}" alt="{{block.settings.title | default: col.title}}" loading="lazy" style="width:100%;height:100%;object-fit:contain;transition:transform 0.4s;">
            {%- elsif col.image -%}
              <img src="{{col.image | image_url: width:300}}" alt="{{col.title}}" loading="lazy" style="width:100%;height:100%;object-fit:contain;transition:transform 0.4s;">
            {%- else -%}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--kayva-soft-brown);">
                <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="6" y="10" width="24" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="18" cy="19" r="5" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
            {%- endif -%}
          </div>
          <span class="kayva-collection-tile__title">{{block.settings.title | default: col.title}}</span>
          {%- if section.settings.show_count and col.products_count > 0 -%}
            <span style="font-family:var(--kayva-font);font-size:11px;color:var(--kayva-soft-brown);">{{col.products_count}} products</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.btn_label != blank -%}
      <div style="text-align:center;margin-top:40px;">
        <a href="{{section.settings.btn_url}}" class="kayva-btn kayva-btn--primary">{{section.settings.btn_label}}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{"name":"KAYVA Collection Showcase","max_blocks":6,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Browse"},
{"type":"text","id":"heading","label":"Heading","default":"Shop by category."},
{"type":"select","id":"text_align","label":"Alignment","options":[{"value":"left","label":"Left"},{"value":"center","label":"Centre"}],"default":"center"},
{"type":"color","id":"bg","label":"Background","default":"#FFFFFF"},
{"type":"range","id":"columns","label":"Columns","min":2,"max":6,"step":1,"default":5},
{"type":"range","id":"gap","label":"Gap (px)","min":4,"max":40,"step":4,"default":12},
{"type":"range","id":"icon_size","label":"Icon size (px)","min":40,"max":160,"step":8,"default":72},
{"type":"range","id":"radius","label":"Border radius (px)","min":0,"max":32,"step":2,"default":8},
{"type":"checkbox","id":"show_count","label":"Show product count","default":false},
{"type":"text","id":"btn_label","label":"Button label"},
{"type":"url","id":"btn_url","label":"Button URL"}
],"blocks":[{"type":"tile","name":"Collection Tile","settings":[
{"type":"collection","id":"collection","label":"Collection"},
{"type":"text","id":"title","label":"Override title"},
{"type":"image_picker","id":"image","label":"Icon image"},
{"type":"url","id":"url","label":"Override URL"}
]}],"presets":[{"name":"KAYVA Collection Showcase","blocks":[
{"type":"tile","settings":{"title":"LED Strip"}},
{"type":"tile","settings":{"title":"GU10"}},
{"type":"tile","settings":{"title":"E27"}},
{"type":"tile","settings":{"title":"Downlights"}},
{"type":"tile","settings":{"title":"Accessories"}}
]}]}
{% endschema %}
