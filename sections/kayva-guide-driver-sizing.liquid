{{ 'kayva.css' | asset_url | stylesheet_tag }}

<style>
.kv-sizing-{{ section.id }} {
  background-color: {{ section.settings.background_color }};
}
.kv-guide__body {
  font-family: var(--kayva-font);
  max-width: 720px;
  margin: 0 auto;
  padding: 64px 24px 80px;
}

.kv-guide__body h2 {
  font-size: clamp(22px, 2.5vw, 30px);
  font-weight: 300;
  color: var(--kayva-dark-brown, #3D2A15);
  letter-spacing: -0.3px;
  margin: 48px 0 16px;
  line-height: 1.2;
}
.kv-guide__body h2:first-child { margin-top: 0; }

.kv-guide__body h3 {
  font-size: 18px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  margin: 32px 0 12px;
}

.kv-guide__body p {
  font-size: 16px;
  color: var(--kayva-warm-brown, #6B4823);
  margin-bottom: 16px;
  line-height: 1.75;
}

/* Calculator */
.kv-calc {
  background: var(--kayva-cream, #F5EFE5);
  padding: 36px;
  margin: 36px 0;
}
.kv-calc__label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 10px;
}
.kv-calc__slider-wrap {
  margin-bottom: 24px;
}
.kv-calc__slider-value {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-bottom: 12px;
}
.kv-calc__slider-num {
  font-size: 40px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  line-height: 1;
}
.kv-calc__slider-unit {
  font-size: 16px;
  color: var(--kayva-soft-brown, #8A5524);
  letter-spacing: 0.05em;
}
.kv-calc__input {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 4px;
  background: linear-gradient(to right, var(--kayva-dark-brown, #3D2A15) var(--kv-pct, 0%), var(--kayva-line, #E8E0D2) var(--kv-pct, 0%));
  outline: none;
  border: none;
  border-radius: 0;
  cursor: ew-resize;
}
.kv-calc__input::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--kayva-dark-brown, #3D2A15);
  cursor: ew-resize;
  border: 3px solid var(--kayva-white, #FFFFFF);
  box-shadow: 0 0 0 1.5px var(--kayva-dark-brown, #3D2A15);
}
.kv-calc__input::-moz-range-thumb {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--kayva-dark-brown, #3D2A15);
  cursor: ew-resize;
  border: 3px solid var(--kayva-white, #FFFFFF);
  box-shadow: 0 0 0 1.5px var(--kayva-dark-brown, #3D2A15);
}
.kv-calc__slider-ticks {
  display: flex;
  justify-content: space-between;
  margin-top: 8px;
  font-size: 11px;
  color: var(--kayva-soft-brown, #8A5524);
  letter-spacing: 0.05em;
}
.kv-calc__result {
  background: var(--kayva-white, #FFFFFF);
  border: 1.5px solid var(--kayva-dark-brown, #3D2A15);
  padding: 28px 24px;
  text-align: center;
}
.kv-calc__result-label {
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--kayva-soft-brown, #8A5524);
  margin-bottom: 8px;
}
.kv-calc__result-value {
  font-size: 38px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  line-height: 1;
  margin-bottom: 8px;
}
.kv-calc__result-sub {
  font-size: 13px;
  color: var(--kayva-warm-brown, #6B4823);
}

/* Reference table */
.kv-guide__table {
  width: 100%;
  border-collapse: collapse;
  margin: 24px 0 36px;
  font-size: 15px;
}
.kv-guide__table th {
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--kayva-dark-brown, #3D2A15);
  padding: 12px 14px;
  border-bottom: 2px solid var(--kayva-line, #E8E0D2);
}
.kv-guide__table td {
  padding: 13px 14px;
  border-bottom: 1px solid var(--kayva-line, #E8E0D2);
  color: var(--kayva-warm-brown, #6B4823);
  line-height: 1.4;
}
.kv-guide__table td:first-child {
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
}
.kv-guide__table tr:last-child td { border-bottom: none; }
.kv-guide__table tr:hover td { background: var(--kayva-cream, #F5EFE5); }

/* Callout */
.kv-callout {
  border-left: 3px solid var(--kayva-amber, #B8753A);
  background: #FBF3E8;
  padding: 18px 22px;
  margin: 28px 0;
  font-size: 15px;
  color: var(--kayva-warm-brown, #6B4823);
  line-height: 1.65;
}
.kv-callout strong { color: var(--kayva-dark-brown, #3D2A15); }

/* Info box */
.kv-info {
  border-left: 3px solid var(--kayva-line, #E8E0D2);
  background: var(--kayva-cream, #F5EFE5);
  padding: 18px 22px;
  margin: 28px 0;
  font-size: 15px;
  color: var(--kayva-warm-brown, #6B4823);
  line-height: 1.65;
}
.kv-info strong { color: var(--kayva-dark-brown, #3D2A15); }

/* Article meta */
.kv-guide__meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  font-size: 12px;
  letter-spacing: 0.08em;
  color: var(--kayva-soft-brown, #8A5524);
  margin-bottom: 48px;
  padding-top: 32px;
  flex-wrap: wrap;
}

/* Rich text */
.kv-guide__rte h2 { font-size: clamp(20px, 2.2vw, 26px); font-weight: 300; color: var(--kayva-dark-brown,#3D2A15); margin: 40px 0 14px; letter-spacing:-0.3px; }
.kv-guide__rte h3 { font-size: 17px; font-weight: 600; color: var(--kayva-dark-brown,#3D2A15); margin: 28px 0 10px; }
.kv-guide__rte p { font-size: 16px; color: var(--kayva-warm-brown,#6B4823); margin-bottom: 16px; line-height: 1.75; }
.kv-guide__rte ul, .kv-guide__rte ol { margin: 16px 0 20px 20px; color: var(--kayva-warm-brown,#6B4823); font-size: 15px; line-height: 1.75; }
.kv-guide__rte li { margin-bottom: 6px; }
.kv-guide__rte a { color: var(--kayva-amber,#B8753A); border-bottom: 1px solid currentColor; }
.kv-guide__rte strong { color: var(--kayva-dark-brown,#3D2A15); font-weight: 600; }
.kv-guide__rte img { max-width: 100%; margin: 24px 0; }
.kv-guide__rte hr { border: none; border-top: 1px solid var(--kayva-line,#E8E0D2); margin: 36px 0; }

@media (max-width: 600px) {
  .kv-guide__body { padding: 48px 16px 64px; }
  .kv-calc { padding: 24px 20px; }
  .kv-guide__table { font-size: 13px; }
  .kv-guide__table th, .kv-guide__table td { padding: 10px 8px; }
}
</style>

{%- liquid
  assign show_rte = section.settings.show_article_content
-%}

<div class="kv-sizing-{{ section.id }}">
  <div class="kv-guide__body">


    {%- if article.published_at and section.settings.show_meta -%}
      <div class="kv-guide__meta">
        <span>{{ article.published_at | date: '%d %B %Y' }}</span>
        {%- if article.author != blank -%}
          <span>&middot;</span>
          <span>{{ article.author }}</span>
        {%- endif -%}
        {%- if article.tags.size > 0 -%}
          <span>&middot;</span>
          <span>{{ article.tags | join: ', ' }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'heading' -%}
          <h2 {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>

        {%- when 'subheading' -%}
          <h3 {{ block.shopify_attributes }}>{{ block.settings.text }}</h3>

        {%- when 'text' -%}
          <div {{ block.shopify_attributes }}>{{ block.settings.content }}</div>

        {%- when 'callout' -%}
          <div class="kv-callout" {{ block.shopify_attributes }}>
            {%- if block.settings.label != blank -%}
              <strong>{{ block.settings.label }}</strong><br>
            {%- endif -%}
            {{ block.settings.text }}
          </div>

        {%- when 'info' -%}
          <div class="kv-info" {{ block.shopify_attributes }}>
            {%- if block.settings.label != blank -%}
              <strong>{{ block.settings.label }}</strong><br>
            {%- endif -%}
            {{ block.settings.text }}
          </div>

        {%- when 'calculator' -%}
          <div class="kv-calc" {{ block.shopify_attributes }} id="kv-calc-{{ block.id }}">
            <label class="kv-calc__label" for="kv-input-{{ block.id }}">
              {{ block.settings.label }}
            </label>
            <div class="kv-calc__slider-wrap">
              <div class="kv-calc__slider-value">
                <span class="kv-calc__slider-num" id="kv-num-{{ block.id }}">{{ block.settings.default_value }}</span>
                <span class="kv-calc__slider-unit">{{ block.settings.unit }}</span>
              </div>
              <input class="kv-calc__input"
                     type="range"
                     id="kv-input-{{ block.id }}"
                     value="{{ block.settings.default_value }}"
                     min="{{ block.settings.slider_min | default: 1 }}"
                     max="{{ block.settings.slider_max | default: 30 }}"
                     step="0.5">
              <div class="kv-calc__slider-ticks">
                <span>{{ block.settings.slider_min | default: 1 }}{{ block.settings.unit }}</span>
                <span>{{ block.settings.slider_max | default: 30 }}{{ block.settings.unit }}</span>
              </div>
            </div>
            <div class="kv-calc__result">
              <p class="kv-calc__result-label">{{ block.settings.result_label }}</p>
              <p class="kv-calc__result-value" id="kv-out-{{ block.id }}">—</p>
              <p class="kv-calc__result-sub" id="kv-sub-{{ block.id }}"></p>
            </div>
          </div>
          <script>
            (function(){
              var inp = document.getElementById('kv-input-{{ block.id }}');
              var num = document.getElementById('kv-num-{{ block.id }}');
              var out = document.getElementById('kv-out-{{ block.id }}');
              var sub = document.getElementById('kv-sub-{{ block.id }}');
              var wpm = {{ block.settings.watts_per_unit }};
              var headroom = {{ block.settings.headroom_percent }};
              var unit = '{{ block.settings.unit }}';
              var suffix = '{{ block.settings.result_suffix }}';
              var min = parseFloat(inp.min);
              var max = parseFloat(inp.max);
              function run(){
                var v = parseFloat(inp.value)||0;
                num.textContent = v % 1 === 0 ? v : v.toFixed(1);
                var pct = ((v - min) / (max - min) * 100).toFixed(1);
                inp.style.setProperty('--kv-pct', pct + '%');
                var draw = v * wpm;
                var rec = Math.ceil(draw * (1 + headroom/100));
                out.textContent = rec + suffix;
                sub.textContent = v + unit + ' × ' + wpm + 'W = ' + draw + 'W, + ' + headroom + '% headroom';
              }
              inp.addEventListener('input', run);
              run();
            })();
          </script>

        {%- when 'table' -%}
          <table class="kv-guide__table" {{ block.shopify_attributes }}>
            {%- if block.settings.header_row != blank -%}
              <thead>
                <tr>
                  {%- assign headers = block.settings.header_row | split: '|' -%}
                  {%- for h in headers -%}
                    <th>{{ h | strip }}</th>
                  {%- endfor -%}
                </tr>
              </thead>
            {%- endif -%}
            <tbody>
              {%- assign rows = block.settings.rows | newline_to_br | split: '<br />' -%}
              {%- for row in rows -%}
                {%- assign row_clean = row | strip -%}
                {%- if row_clean != blank -%}
                  <tr>
                    {%- assign cells = row_clean | split: '|' -%}
                    {%- for cell in cells -%}
                      <td>{{ cell | strip }}</td>
                    {%- endfor -%}
                  </tr>
                {%- endif -%}
              {%- endfor -%}
            </tbody>
          </table>

        {%- when 'divider' -%}
          <hr style="border:none;border-top:1px solid var(--kayva-line,#E8E0D2);margin:40px 0;" {{ block.shopify_attributes }}>

        {%- when 'spacer' -%}
          <div style="height:{{ block.settings.height }}px;" {{ block.shopify_attributes }}></div>

      {%- endcase -%}
    {%- endfor -%}

    {%- if show_rte and article.content != blank -%}
      <div class="kv-guide__rte">
        {{ article.content }}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "KAYVA Guide Driver Sizing",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Article meta"
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "Show date / author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_article_content",
      "label": "Also show article body (from Shopify editor)",
      "default": false,
      "info": "Enable to append the Shopify article rich-text body after the blocks."
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading (H2)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading text",
          "default": "The simple rule"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading (H3)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading text"
        }
      ]
    },
    {
      "type": "text",
      "name": "Body text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    },
    {
      "type": "callout",
      "name": "Callout (amber)",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Bold label",
          "default": "Important:"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Callout text"
        }
      ]
    },
    {
      "type": "info",
      "name": "Info box (neutral)",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Bold label"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Info text"
        }
      ]
    },
    {
      "type": "calculator",
      "name": "Calculator",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Input label",
          "default": "Your strip length (metres)"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Input placeholder",
          "default": "e.g. 10"
        },
        {
          "type": "range",
          "id": "default_value",
          "label": "Default value",
          "min": 1,
          "max": 50,
          "step": 1,
          "default": 10
        },
        {
          "type": "text",
          "id": "result_label",
          "label": "Result label",
          "default": "Minimum driver size"
        },
        {
          "type": "text",
          "id": "result_suffix",
          "label": "Result unit suffix",
          "default": "W"
        },
        {
          "type": "range",
          "id": "watts_per_unit",
          "label": "Watts per unit (W/m)",
          "min": 1,
          "max": 30,
          "step": 1,
          "default": 12
        },
        {
          "type": "range",
          "id": "headroom_percent",
          "label": "Headroom %",
          "min": 0,
          "max": 50,
          "step": 5,
          "default": 20
        },
        {
          "type": "text",
          "id": "unit",
          "label": "Input unit label",
          "default": "m"
        },
        {
          "type": "range",
          "id": "slider_min",
          "label": "Slider minimum",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1
        },
        {
          "type": "range",
          "id": "slider_max",
          "label": "Slider maximum",
          "min": 10,
          "max": 100,
          "step": 5,
          "default": 30
        }
      ]
    },
    {
      "type": "table",
      "name": "Reference table",
      "settings": [
        {
          "type": "text",
          "id": "header_row",
          "label": "Header row (pipe-separated)",
          "default": "Strip length | Power draw | Recommended driver",
          "info": "Separate columns with |"
        },
        {
          "type": "textarea",
          "id": "rows",
          "label": "Table rows (one per line, pipe-separated)",
          "default": "3 m | 36W | 45W (24V)\n5 m | 60W | 75W (24V)\n8 m | 96W | 120W (24V)\n10 m | 120W | 150W (24V)\n15 m | 180W | 220W (24V)\n20 m | 240W | 300W (24V)",
          "info": "One row per line. Separate columns with |"
        }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": []
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        {
          "type": "range",
          "id": "height",
          "label": "Height (px)",
          "min": 8,
          "max": 80,
          "step": 4,
          "default": 24
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KAYVA Guide Driver Sizing",
      "settings": {
        "background_color": "#FFFFFF",
        "show_meta": true
      },
      "blocks": [
        {
          "type": "heading",
          "settings": { "text": "The simple rule" }
        },
        {
          "type": "text",
          "settings": { "content": "<p>Multiply your strip length by 12W per metre, then add 20% headroom so the driver isn't running at full capacity. A driver running flat-out runs hot and fails early.</p>" }
        },
        {
          "type": "calculator",
          "settings": {
            "label": "Your strip length (metres)",
            "placeholder": "e.g. 10",
            "default_value": 10,
            "result_label": "Minimum driver size",
            "result_suffix": "W",
            "watts_per_unit": 12,
            "headroom_percent": 20,
            "unit": "m"
          }
        },
        {
          "type": "heading",
          "settings": { "text": "Quick reference" }
        },
        {
          "type": "table",
          "settings": {
            "header_row": "Strip length | Power draw | Recommended driver",
            "rows": "3 m | 36W | 45W (24V)\n5 m | 60W | 75W (24V)\n8 m | 96W | 120W (24V)\n10 m | 120W | 150W (24V)\n15 m | 180W | 220W (24V)\n20 m | 240W | 300W (24V)"
          }
        },
        {
          "type": "callout",
          "settings": {
            "label": "For runs 6 m and longer:",
            "text": "Power the strip from both ends, or split into segments with separate feeds. This prevents voltage drop, where the far end of a long run appears dimmer than the start."
          }
        },
        {
          "type": "heading",
          "settings": { "text": "What driver to buy" }
        },
        {
          "type": "text",
          "settings": { "content": "<p>Use a 24V constant-voltage LED driver. For dimmable installations, choose a TRIAC-dimmable 24V driver and pair it with a compatible wall dimmer. KAYVA strip itself doesn't dim on its own — the driver controls dimming.</p>" }
        },
        {
          "type": "callout",
          "settings": {
            "label": "Always use a licensed electrician",
            "text": "for connecting the driver to mains power in Singapore. The low-voltage side (driver to strip) is safe to handle when unpowered."
          }
        }
      ]
    }
  ]
}
{% endschema %}
