{{ 'kayva.css' | asset_url | stylesheet_tag }}

<style>
.kv-cta-{{ section.id }} {
  background-color: {{ section.settings.background_color }};
  padding: 56px 24px;
  text-align: center;
}
.kv-cta-{{ section.id }} h2 {
  font-size: clamp(22px, 3vw, 32px);
  font-weight: 300;
  color: {{ section.settings.heading_color }};
  margin-bottom: 12px;
  font-family: var(--kayva-font);
}
.kv-cta-{{ section.id }} p {
  font-size: 15px;
  color: {{ section.settings.text_color }};
  margin-bottom: 28px;
  font-family: var(--kayva-font);
}
</style>

<div class="kv-cta-{{ section.id }}">
  <div class="kayva-page-width">
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p>{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_url }}" class="kayva-btn kayva-btn--ghost">
        {{ section.settings.btn_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "KAYVA Guide CTA",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#3D2A15"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#F5EFE5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text colour",
      "default": "#A8967E"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to hide this section."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "KAYVA Guide CTA",
      "settings": {
        "background_color": "#3D2A15",
        "heading_color": "#F5EFE5",
        "text_color": "#A8967E",
        "heading": "Ready to order your strip?",
        "subtext": "KAYVA 480 Pro Strip — Ra95+, 24V, dotless COB. Available in 2700K and 4000K.",
        "btn_label": "Shop Strip Lighting",
        "btn_url": "/collections/all"
      }
    }
  ]
}
{% endschema %}
