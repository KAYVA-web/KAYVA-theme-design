{{ 'kayva.css' | asset_url | stylesheet_tag }}

<style>
/* ===== GUIDE ARTICLE STYLES ===== */
.kv-guide { font-family: var(--kayva-font); }

/* Hero */
.kv-guide__hero {
  background: var(--kayva-cream, #F5EFE5);
  padding: 72px 0 64px;
  text-align: center;
}
.kv-guide__hero-eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--kayva-amber, #B8753A);
  margin-bottom: 14px;
}
.kv-guide__hero-title {
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 300;
  color: var(--kayva-dark-brown, #3D2A15);
  letter-spacing: -0.5px;
  line-height: 1.1;
  margin-bottom: 16px;
}
.kv-guide__hero-sub {
  font-size: clamp(15px, 1.5vw, 18px);
  color: var(--kayva-warm-brown, #6B4823);
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.65;
}

/* Content area */
.kv-guide__body {
  max-width: 720px;
  margin: 0 auto;
  padding: 64px 24px 80px;
}

/* Headings */
.kv-guide__body h2 {
  font-size: clamp(22px, 2.5vw, 30px);
  font-weight: 300;
  color: var(--kayva-dark-brown, #3D2A15);
  letter-spacing: -0.3px;
  margin: 48px 0 16px;
  line-height: 1.2;
}
.kv-guide__body h2:first-child { margin-top: 0; }

.kv-guide__body h3 {
  font-size: 18px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  margin: 32px 0 12px;
}

.kv-guide__body p {
  font-size: 16px;
  color: var(--kayva-warm-brown, #6B4823);
  margin-bottom: 16px;
  line-height: 1.75;
}

/* Calculator block */
.kv-calc {
  background: var(--kayva-cream, #F5EFE5);
  padding: 36px;
  margin: 36px 0;
}
.kv-calc__label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--kayva-dark-brown, #3D2A15);
  margin-bottom: 10px;
}
.kv-calc__input {
  width: 100%;
  padding: 14px 16px;
  border: 1.5px solid var(--kayva-line, #E8E0D2);
  font-family: var(--kayva-font);
  font-size: 16px;
  color: var(--kayva-ink, #1F1B16);
  background: var(--kayva-white, #FFFFFF);
  outline: none;
  margin-bottom: 24px;
  border-radius: 0;
  transition: border-color 0.2s;
}
.kv-calc__input:focus { border-color: var(--kayva-dark-brown, #3D2A15); }
.kv-calc__result {
  background: var(--kayva-white, #FFFFFF);
  border: 1.5px solid var(--kayva-dark-brown, #3D2A15);
  padding: 28px 24px;
  text-align: center;
}
.kv-calc__result-label {
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--kayva-soft-brown, #8A5524);
  margin-bottom: 8px;
}
.kv-calc__result-value {
  font-size: 38px;
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
  line-height: 1;
  margin-bottom: 8px;
}
.kv-calc__result-sub {
  font-size: 13px;
  color: var(--kayva-warm-brown, #6B4823);
}

/* Reference table */
.kv-guide__table {
  width: 100%;
  border-collapse: collapse;
  margin: 24px 0 36px;
  font-size: 15px;
}
.kv-guide__table th {
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--kayva-dark-brown, #3D2A15);
  padding: 12px 14px;
  border-bottom: 2px solid var(--kayva-line, #E8E0D2);
}
.kv-guide__table td {
  padding: 13px 14px;
  border-bottom: 1px solid var(--kayva-line, #E8E0D2);
  color: var(--kayva-warm-brown, #6B4823);
  line-height: 1.4;
}
.kv-guide__table td:first-child {
  font-weight: 600;
  color: var(--kayva-dark-brown, #3D2A15);
}
.kv-guide__table tr:last-child td { border-bottom: none; }
.kv-guide__table tr:hover td { background: var(--kayva-cream, #F5EFE5); }

/* Callout / warning box */
.kv-callout {
  border-left: 3px solid var(--kayva-amber, #B8753A);
  background: #FBF3E8;
  padding: 18px 22px;
  margin: 28px 0;
  font-size: 15px;
  color: var(--kayva-warm-brown, #6B4823);
  line-height: 1.65;
}
.kv-callout strong { color: var(--kayva-dark-brown, #3D2A15); }

/* Info box (neutral) */
.kv-info {
  border-left: 3px solid var(--kayva-line, #E8E0D2);
  background: var(--kayva-cream, #F5EFE5);
  padding: 18px 22px;
  margin: 28px 0;
  font-size: 15px;
  color: var(--kayva-warm-brown, #6B4823);
  line-height: 1.65;
}
.kv-info strong { color: var(--kayva-dark-brown, #3D2A15); }

/* Article meta */
.kv-guide__meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  font-size: 12px;
  letter-spacing: 0.08em;
  color: var(--kayva-soft-brown, #8A5524);
  margin-bottom: 48px;
  padding-top: 32px;
  flex-wrap: wrap;
}

/* Back to blog link */
.kv-guide__back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--kayva-soft-brown, #8A5524);
  text-decoration: none;
  margin-bottom: 48px;
  transition: color 0.2s;
}
.kv-guide__back:hover { color: var(--kayva-amber, #B8753A); }

/* Rich text from article.content */
.kv-guide__rte h2 { font-size: clamp(20px, 2.2vw, 26px); font-weight: 300; color: var(--kayva-dark-brown,#3D2A15); margin: 40px 0 14px; letter-spacing:-0.3px; }
.kv-guide__rte h3 { font-size: 17px; font-weight: 600; color: var(--kayva-dark-brown,#3D2A15); margin: 28px 0 10px; }
.kv-guide__rte p { font-size: 16px; color: var(--kayva-warm-brown,#6B4823); margin-bottom: 16px; line-height: 1.75; }
.kv-guide__rte ul, .kv-guide__rte ol { margin: 16px 0 20px 20px; color: var(--kayva-warm-brown,#6B4823); font-size: 15px; line-height: 1.75; }
.kv-guide__rte li { margin-bottom: 6px; }
.kv-guide__rte a { color: var(--kayva-amber,#B8753A); border-bottom: 1px solid currentColor; }
.kv-guide__rte strong { color: var(--kayva-dark-brown,#3D2A15); font-weight: 600; }
.kv-guide__rte img { max-width: 100%; margin: 24px 0; }
.kv-guide__rte hr { border: none; border-top: 1px solid var(--kayva-line,#E8E0D2); margin: 36px 0; }

/* Related/CTA banner */
.kv-guide__cta {
  background: var(--kayva-dark-brown, #3D2A15);
  padding: 56px 24px;
  text-align: center;
  margin-top: 0;
}
.kv-guide__cta h2 {
  font-size: clamp(22px, 3vw, 32px);
  font-weight: 300;
  color: var(--kayva-cream, #F5EFE5);
  margin-bottom: 12px;
}
.kv-guide__cta p {
  font-size: 15px;
  color: rgba(245,239,229,0.7);
  margin-bottom: 28px;
}

@media (max-width: 600px) {
  .kv-guide__body { padding: 48px 16px 64px; }
  .kv-calc { padding: 24px 20px; }
  .kv-guide__table { font-size: 13px; }
  .kv-guide__table th, .kv-guide__table td { padding: 10px 8px; }
}
</style>

{%- liquid
  assign show_hero = section.settings.show_hero
  assign show_rte = section.settings.show_article_content
-%}

<article class="kv-guide">

  {%- if show_hero -%}
  <div class="kv-guide__hero">
    <div class="kayva-page-width">
      {%- if section.settings.eyebrow != blank -%}
        <p class="kv-guide__hero-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="kv-guide__hero-title">
        {%- if section.settings.title != blank -%}
          {{ section.settings.title }}
        {%- else -%}
          {{ article.title }}
        {%- endif -%}
      </h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="kv-guide__hero-sub">{{ section.settings.subtitle }}</p>
      {%- elsif article.excerpt != blank -%}
        <p class="kv-guide__hero-sub">{{ article.excerpt | strip_html }}</p>
      {%- endif -%}
    </div>
  </div>
  {%- endif -%}

  <div class="kv-guide__body">

    <!-- Back to blog -->
    {%- if section.settings.show_back_link -%}
      <a href="{{ blog.url | default: '/blogs/guides' }}" class="kv-guide__back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M10 7H4M6 4L3 7l3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ section.settings.back_label | default: 'All guides' }}
      </a>
    {%- endif -%}

    <!-- Article meta -->
    {%- if article.published_at and section.settings.show_meta -%}
      <div class="kv-guide__meta">
        <span>{{ article.published_at | date: '%d %B %Y' }}</span>
        {%- if article.author != blank -%}
          <span>&middot;</span>
          <span>{{ article.author }}</span>
        {%- endif -%}
        {%- if article.tags.size > 0 -%}
          <span>&middot;</span>
          <span>{{ article.tags | join: ', ' }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- ===== GUIDE CONTENT BLOCKS ===== -->
    {%- for block in section.blocks -%}

      {%- case block.type -%}

        {%- when 'heading' -%}
          <h2 {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>

        {%- when 'subheading' -%}
          <h3 {{ block.shopify_attributes }}>{{ block.settings.text }}</h3>

        {%- when 'text' -%}
          <div {{ block.shopify_attributes }}>{{ block.settings.content }}</div>

        {%- when 'callout' -%}
          <div class="kv-callout" {{ block.shopify_attributes }}>
            {%- if block.settings.label != blank -%}
              <strong>{{ block.settings.label }}</strong><br>
            {%- endif -%}
            {{ block.settings.text }}
          </div>

        {%- when 'info' -%}
          <div class="kv-info" {{ block.shopify_attributes }}>
            {%- if block.settings.label != blank -%}
              <strong>{{ block.settings.label }}</strong><br>
            {%- endif -%}
            {{ block.settings.text }}
          </div>

        {%- when 'calculator' -%}
          <div class="kv-calc" {{ block.shopify_attributes }} id="kv-calc-{{ block.id }}">
            <label class="kv-calc__label" for="kv-input-{{ block.id }}">
              {{ block.settings.label }}
            </label>
            <input class="kv-calc__input"
                   type="number"
                   id="kv-input-{{ block.id }}"
                   placeholder="{{ block.settings.placeholder }}"
                   value="{{ block.settings.default_value }}"
                   min="0"
                   step="0.5">
            <div class="kv-calc__result">
              <p class="kv-calc__result-label">{{ block.settings.result_label }}</p>
              <p class="kv-calc__result-value" id="kv-out-{{ block.id }}">—</p>
              <p class="kv-calc__result-sub" id="kv-sub-{{ block.id }}"></p>
            </div>
          </div>
          <script>
            (function(){
              var inp = document.getElementById('kv-input-{{ block.id }}');
              var out = document.getElementById('kv-out-{{ block.id }}');
              var sub = document.getElementById('kv-sub-{{ block.id }}');
              var wpm = {{ block.settings.watts_per_unit }};
              var headroom = {{ block.settings.headroom_percent }};
              var unit = '{{ block.settings.unit }}';
              var suffix = '{{ block.settings.result_suffix }}';
              function run(){
                var v = parseFloat(inp.value)||0;
                var draw = v * wpm;
                var rec = Math.ceil(draw * (1 + headroom/100));
                out.textContent = rec + suffix;
                sub.textContent = v + unit + ' × ' + wpm + 'W = ' + draw + 'W, + ' + headroom + '% headroom';
              }
              inp.addEventListener('input', run);
              run();
            })();
          </script>

        {%- when 'table' -%}
          <table class="kv-guide__table" {{ block.shopify_attributes }}>
            {%- if block.settings.header_row != blank -%}
              <thead>
                <tr>
                  {%- assign headers = block.settings.header_row | split: '|' -%}
                  {%- for h in headers -%}
                    <th>{{ h | strip }}</th>
                  {%- endfor -%}
                </tr>
              </thead>
            {%- endif -%}
            <tbody>
              {%- assign rows = block.settings.rows | newline_to_br | split: '<br />' -%}
              {%- for row in rows -%}
                {%- assign row_clean = row | strip -%}
                {%- if row_clean != blank -%}
                  <tr>
                    {%- assign cells = row_clean | split: '|' -%}
                    {%- for cell in cells -%}
                      <td>{{ cell | strip }}</td>
                    {%- endfor -%}
                  </tr>
                {%- endif -%}
              {%- endfor -%}
            </tbody>
          </table>

        {%- when 'divider' -%}
          <hr style="border:none;border-top:1px solid var(--kayva-line,#E8E0D2);margin:40px 0;" {{ block.shopify_attributes }}>

        {%- when 'spacer' -%}
          <div style="height:{{ block.settings.height }}px;" {{ block.shopify_attributes }}></div>

      {%- endcase -%}

    {%- endfor -%}

    <!-- Article rich-text body (from Shopify article editor) -->
    {%- if show_rte and article.content != blank -%}
      <div class="kv-guide__rte">
        {{ article.content }}
      </div>
    {%- endif -%}

  </div>

  <!-- CTA banner at bottom -->
  {%- if section.settings.cta_heading != blank -%}
    <div class="kv-guide__cta">
      <div class="kayva-page-width">
        <h2>{{ section.settings.cta_heading }}</h2>
        {%- if section.settings.cta_text != blank -%}
          <p>{{ section.settings.cta_text }}</p>
        {%- endif -%}
        {%- if section.settings.cta_btn_label != blank -%}
          <a href="{{ section.settings.cta_btn_url }}" class="kayva-btn kayva-btn--ghost">
            {{ section.settings.cta_btn_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</article>

{% schema %}
