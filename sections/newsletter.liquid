<style>
  .newsletter-section {
    background: {{ section.settings.background_color }};
  }
  .newsletter-section__inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .newsletter__form {
    display: flex;
    gap: 0;
    width: 100%;
    max-width: 440px;
  }
  .newsletter__input {
    flex: 1;
    padding: 14px 18px;
    border: 1.5px solid {{ section.settings.border_color }};
    border-right: none;
    font-size: 14px;
    background: transparent;
    color: {{ section.settings.text_color }};
    outline: none;
    border-radius: 0;
  }
  .newsletter__input::placeholder { opacity: 0.5; color: {{ section.settings.text_color }}; }
  .newsletter__input:focus { border-color: {{ section.settings.text_color }}; }
  .newsletter__submit {
    padding: 14px 22px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1.5px solid {{ section.settings.button_bg }};
    cursor: pointer;
    transition: opacity 0.2s;
    border-radius: 0;
  }
  .newsletter__submit:hover { opacity: 0.85; }
  .newsletter__message {
    font-size: 13px;
    min-height: 20px;
  }
  .newsletter__disclaimer {
    font-size: 11px;
    opacity: 0.5;
    color: {{ section.settings.text_color }};
  }
  @media (max-width: 480px) {
    .newsletter__form { flex-direction: column; }
    .newsletter__input { border-right: 1.5px solid {{ section.settings.border_color }}; }
  }
</style>

<section class="newsletter-section section" id="section-{{ section.id }}">
  <div class="page-width">
    <div class="newsletter-section__inner">
      {%- if section.settings.eyebrow != blank -%}
        <p class="label" style="color:{{ section.settings.text_color }};opacity:0.6;">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading" style="color:{{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p style="font-size:14px; color:{{ section.settings.text_color }}; opacity:0.7; line-height:1.65;">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'newsletter-form-{{ section.id }}', class: 'newsletter__form', data-newsletter-form: '' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input class="newsletter__input"
               type="email"
               name="contact[email]"
               id="email-{{ section.id }}"
               placeholder="{{ section.settings.placeholder }}"
               autocomplete="email"
               required>
        <button type="submit" class="newsletter__submit">
          {{ section.settings.button_label }}
        </button>
      {%- endform -%}

      <p class="newsletter__message" aria-live="polite"></p>
      <p class="newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lighting guides"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get our Singapore lighting guide."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "CRI explained, Kelvin guide, and cove lighting tips for HDB and condo spaces."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "No spam. Unsubscribe any time."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F5EFE5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#3D2A15"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Input border",
      "default": "#8A5524"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#3D2A15"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#F5EFE5"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
