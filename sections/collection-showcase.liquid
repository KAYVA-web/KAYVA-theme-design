<style>
  .collection-showcase { background: {{ section.settings.background_color }}; }

  .collection-showcase__header {
    text-align: {{ section.settings.text_align }};
    margin-bottom: var(--spacing-lg);
  }

  .collection-grid-showcase {
    display: grid;
    gap: {{ section.settings.grid_gap }}px;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
  }

  /* Each tile — icon card style like Philips Hue */
  .collection-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 20px 12px 16px;
    text-decoration: none;
    border: 1.5px solid var(--color-line);
    border-radius: {{ section.settings.border_radius }}px;
    background: var(--color-white);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
  }

  /* Border lights up on hover — amber glow */
  .collection-tile:hover {
    border-color: var(--color-amber);
    box-shadow: 0 0 0 1px var(--color-amber),
                0 4px 20px rgba(184, 117, 58, 0.15);
  }

  /* Icon-sized image container */
  .collection-tile__image-wrap {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius | divided_by: 2 }}px;
    flex-shrink: 0;
    position: relative;
  }

  .collection-tile__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .collection-tile:hover .collection-tile__image-wrap img {
    transform: scale(1.08);
  }

  /* Placeholder icon when no image */
  .collection-tile__placeholder-icon {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-soft-brown);
  }

  /* Label below icon */
  .collection-tile__title {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-dark-brown);
    text-align: center;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  /* Optional product count */
  .collection-tile__count {
    font-size: 11px;
    color: var(--color-soft-brown);
    text-align: center;
  }

  /* View all button below grid */
  .collection-showcase__footer {
    text-align: center;
    margin-top: var(--spacing-lg);
  }

  @media (max-width: 1024px) {
    .collection-grid-showcase {
      grid-template-columns: repeat({{ section.settings.columns | at_most: 4 }}, 1fr);
    }
  }

  @media (max-width: 600px) {
    .collection-grid-showcase { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 380px) {
    .collection-grid-showcase { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<section class="collection-showcase section" id="section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="collection-showcase__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="label" style="margin-bottom:10px;">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collection-grid-showcase">
      {%- for block in section.blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        {%- assign tile_url = col.url | default: block.settings.custom_url | default: '#' -%}

        <a href="{{ tile_url }}" class="collection-tile" {{ block.shopify_attributes }}>

          <div class="collection-tile__image-wrap">
            {%- if block.settings.custom_image != blank -%}
              <img src="{{ block.settings.custom_image | image_url: width: 300 }}"
                   alt="{{ block.settings.custom_image.alt | escape | default: block.settings.title }}"
                   loading="lazy"
                   width="{{ section.settings.icon_size }}"
                   height="{{ section.settings.icon_size }}">
            {%- elsif col.image != blank -%}
              <img src="{{ col.image | image_url: width: 300 }}"
                   alt="{{ col.image.alt | escape | default: col.title }}"
                   loading="lazy">
            {%- else -%}
              <div class="collection-tile__placeholder-icon">
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                  <rect x="8" y="14" width="24" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="20" cy="23" r="4" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M14 14v-2a6 6 0 0112 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
            {%- endif -%}
          </div>

          <span class="collection-tile__title">
            {{ block.settings.title | default: col.title }}
          </span>

          {%- if section.settings.show_product_count and col.products_count > 0 -%}
            <span class="collection-tile__count">{{ col.products_count }} products</span>
          {%- endif -%}

        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.view_all_label != blank -%}
      <div class="collection-showcase__footer">
        <a href="{{ section.settings.view_all_url }}" class="btn btn--primary">
          {{ section.settings.view_all_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Collection Showcase",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Browse"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by category."
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between tiles (px)",
      "min": 4,
      "max": 40,
      "step": 4,
      "default": 12
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon image size (px)",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 72
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner roundness (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": false
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button label",
      "info": "Leave blank to hide the button."
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "collection_tile",
      "name": "Collection Tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override title (optional)",
          "info": "Leave blank to use the collection title."
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Icon image",
          "info": "Upload a small icon or product image. Transparent PNG works best."
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Override link URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Showcase",
      "blocks": [
        { "type": "collection_tile", "settings": { "title": "LED Strip" } },
        { "type": "collection_tile", "settings": { "title": "GU10 Bulbs" } },
        { "type": "collection_tile", "settings": { "title": "E27 Bulbs" } },
        { "type": "collection_tile", "settings": { "title": "Downlights" } },
        { "type": "collection_tile", "settings": { "title": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}
