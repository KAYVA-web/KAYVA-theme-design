<style>
  .collection-showcase { background: {{ section.settings.background_color }}; }

  .collection-showcase__header {
    text-align: {{ section.settings.text_align }};
    margin-bottom: var(--spacing-lg);
  }

  .collection-grid-showcase {
    display: grid;
    gap: {{ section.settings.grid_gap }}px;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
  }

  /* Each collection tile */
  .collection-tile {
    display: block;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    border: 2px solid transparent;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    background: var(--color-cream);
  }

  /* Border glow on hover — using the brand amber */
  .collection-tile:hover {
    border-color: var(--color-amber);
    box-shadow: 0 0 0 1px var(--color-amber),
                0 0 20px rgba(184, 117, 58, 0.20);
  }

  /* Image: background stays still, only img zooms */
  .collection-tile__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_ratio }};
  }

  .collection-tile__image-bg {
    position: absolute;
    inset: 0;
    background: var(--color-cream);
    z-index: 0;
  }

  .collection-tile__image-wrap img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform-origin: center center;
  }

  .collection-tile:hover .collection-tile__image-wrap img {
    transform: scale(1.06);
  }

  /* Overlay */
  .collection-tile__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(to top, rgba(31,27,22,0.55) 0%, transparent 55%);
    transition: opacity 0.3s;
  }

  .collection-tile:hover .collection-tile__overlay {
    opacity: 0.85;
  }

  /* Text over image */
  .collection-tile__info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    padding: 20px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .collection-tile__title {
    font-weight: 600;
    font-size: clamp(14px, 1.5vw, 17px);
    color: var(--color-white);
    line-height: 1.25;
  }

  .collection-tile__count {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.65);
    white-space: nowrap;
  }

  /* Arrow that slides in on hover */
  .collection-tile__arrow {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    width: 32px;
    height: 32px;
    background: var(--color-amber);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .collection-tile:hover .collection-tile__arrow {
    opacity: 1;
    transform: translateY(0);
  }

  /* Placeholder when no image */
  .collection-tile__placeholder {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 1024px) {
    .collection-grid-showcase {
      grid-template-columns: repeat({{ section.settings.columns | at_most: 3 }}, 1fr);
    }
  }

  @media (max-width: 768px) {
    .collection-grid-showcase { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .collection-grid-showcase { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>

<section class="collection-showcase section" id="section-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="collection-showcase__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="label" style="margin-bottom:10px;">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collection-grid-showcase">
      {%- for block in section.blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        {%- assign tile_url = col.url | default: block.settings.custom_url | default: '#' -%}

        <a href="{{ tile_url }}" class="collection-tile" {{ block.shopify_attributes }}>

          <div class="collection-tile__image-wrap">
            <div class="collection-tile__image-bg"></div>

            {%- if block.settings.custom_image != blank -%}
              <img src="{{ block.settings.custom_image | image_url: width: 800 }}"
                   srcset="{{ block.settings.custom_image | image_url: width: 400 }} 400w,
                           {{ block.settings.custom_image | image_url: width: 800 }} 800w"
                   sizes="(max-width: 480px) calc(50vw - 10px),
                          (max-width: 768px) calc(50vw - 20px),
                          calc({{ 100 | divided_by: section.settings.columns }}vw - 40px)"
                   alt="{{ block.settings.custom_image.alt | escape | default: block.settings.title }}">
            {%- elsif col.image != blank -%}
              <img src="{{ col.image | image_url: width: 800 }}"
                   alt="{{ col.image.alt | escape | default: col.title }}"
                   loading="lazy">
            {%- else -%}
              <div class="collection-tile__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            <div class="collection-tile__overlay"></div>

            <!-- Arrow badge -->
            <span class="collection-tile__arrow" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>

            <div class="collection-tile__info">
              <span class="collection-tile__title">
                {{ block.settings.title | default: col.title }}
              </span>
              {%- if section.settings.show_product_count and col.products_count > 0 -%}
                <span class="collection-tile__count">{{ col.products_count }} products</span>
              {%- endif -%}
            </div>
          </div>

        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Collection Showcase",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Browse"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by category."
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns on desktop (max 6 tiles)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between tiles (px)",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Tile image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "16 / 9", "label": "Wide (16:9)" }
      ],
      "default": "4 / 3"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "collection_tile",
      "name": "Collection Tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Title is pulled from the collection automatically."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override title (optional)",
          "info": "Leave blank to use the collection title."
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom tile image (optional)",
          "info": "Overrides the collection image. Recommended: minimum 800×600px."
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom link URL (optional)",
          "info": "Overrides the collection URL if needed."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Showcase",
      "blocks": [
        { "type": "collection_tile", "settings": { "title": "LED Strip" } },
        { "type": "collection_tile", "settings": { "title": "GU10 Bulbs" } },
        { "type": "collection_tile", "settings": { "title": "E27 Bulbs" } }
      ]
    }
  ]
}
{% endschema %}
