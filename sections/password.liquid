<div style="text-align:center; max-width:480px; width:100%; padding:48px 24px; margin:0 auto;">
  <a href="{{ shop.url }}"
     style="font-family:'Inter',sans-serif; font-weight:600; font-size:22px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-dark-brown); text-decoration:none; display:block; margin-bottom:32px;">
    {{ shop.name }}
  </a>

  {%- if section.settings.heading != blank -%}
    <h1 style="font-family:'Inter',sans-serif; font-weight:300; font-size:clamp(28px,4vw,40px); color:var(--color-dark-brown); line-height:1.15; margin-bottom:16px;">
      {{ section.settings.heading }}
    </h1>
  {%- endif -%}

  {%- if section.settings.subtext != blank -%}
    <p style="font-size:15px; color:var(--color-warm-brown); line-height:1.7; margin-bottom:32px;">
      {{ section.settings.subtext }}
    </p>
  {%- endif -%}

  {%- form 'storefront_password', id: 'password-form' -%}
    {%- if form.errors -%}
      <p style="font-size:13px; color:#c0392b; margin-bottom:16px;">Wrong password. Please try again.</p>
    {%- endif -%}
    <div style="display:flex; max-width:360px; margin:0 auto 24px;">
      <input type="password" name="password" placeholder="{{ section.settings.input_placeholder }}"
             style="flex:1; padding:14px 18px; border:1.5px solid var(--color-line); border-right:none;
                    font-family:'Inter',sans-serif; font-size:14px; outline:none; background:var(--color-white);">
      <button type="submit"
              style="padding:14px 22px; background:var(--color-dark-brown); color:var(--color-cream);
                     font-family:'Inter',sans-serif; font-size:12px; font-weight:500; letter-spacing:0.1em;
                     text-transform:uppercase; border:none; cursor:pointer;">
        {{ section.settings.button_label }}
      </button>
    </div>
  {%- endform -%}

  {%- if section.settings.admin_link_text != blank -%}
    <p style="font-size:12px; color:var(--color-soft-brown);">
      Are you the store owner?
      <a href="/admin" style="color:var(--color-warm-brown);">{{ section.settings.admin_link_text }}</a>
    </p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Ra95+ lighting, properly specified, designed for Singapore homes."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Password input placeholder",
      "default": "Enter password"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Enter"
    },
    {
      "type": "text",
      "id": "admin_link_text",
      "label": "Admin link text",
      "default": "Log in here"
    }
  ]
}
{% endschema %}
