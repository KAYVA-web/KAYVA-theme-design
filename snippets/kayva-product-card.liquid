{% comment %}
  KAYVA product card snippet.
  Usage: {% render 'kayva-product-card', product: product %}
  Feature bullets: add product tags like "feature:LED integrated"
{% endcomment %}
{%- liquid
  assign kv_variant = product.selected_or_first_available_variant
  assign kv_on_sale = false
  if kv_variant.compare_at_price > kv_variant.price
    assign kv_on_sale = true
  endif
  assign kv_has_features = false
  for tag in product.tags
    if tag contains 'feature:'
      assign kv_has_features = true
    endif
  endfor
-%}

<div class="kayva-product-card">
  <a href="{{ product.url }}" class="kayva-product-card__image">
    <div class="kayva-product-card__image-bg"></div>
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}"
           srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                   {{ product.featured_image | image_url: width: 600 }} 600w,
                   {{ product.featured_image | image_url: width: 900 }} 900w"
           sizes="(max-width:480px) calc(50vw - 16px),(max-width:1024px) calc(50vw - 40px),calc(25vw - 32px)"
           alt="{{ product.featured_image.alt | escape | default: product.title }}"
           loading="lazy" width="600" height="600">
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
    {%- if kv_on_sale -%}
      <span class="kayva-badge kayva-badge--sale" style="position:absolute;top:12px;left:12px;z-index:2;">Sale</span>
    {%- endif -%}
  </a>

  <div class="kayva-product-card__info">
    <p class="kayva-product-card__name">{{ product.title }}</p>

    {%- if kv_has_features -%}
      <ul class="kayva-features">
        {%- for tag in product.tags -%}
          {%- if tag contains 'feature:' -%}
            <li class="kayva-feature">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <circle cx="7" cy="7" r="6.5" stroke="currentColor"/>
                <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ tag | remove_first: 'feature:' }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <div style="display:flex;align-items:baseline;gap:6px;margin-top:auto;padding-top:8px;">
      <span class="kayva-product-card__price">{{ kv_variant.price | money }}</span>
      {%- if kv_on_sale -%}
        <span class="kayva-product-card__price-compare">{{ kv_variant.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</div>
