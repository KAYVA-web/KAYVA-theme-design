<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Password Protected</title>
  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--color-cream, #F5EFE5);">
  <div style="text-align:center;max-width:440px;padding:40px 24px;">
    <p style="font-size:11px;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:#B8753A;margin-bottom:16px;">Coming Soon</p>
    <h1 style="font-family:'Inter',sans-serif;font-weight:300;font-size:36px;color:#3D2A15;margin-bottom:16px;">{{ shop.name }}</h1>
    <p style="font-size:15px;color:#6B4823;margin-bottom:32px;">Ra95+ lighting, properly specified, designed for Singapore homes.</p>
    {%- form 'storefront_password' -%}
      <div style="display:flex;gap:0;max-width:320px;margin:0 auto;">
        <input type="password" name="password" placeholder="Enter password"
               style="flex:1;padding:13px 16px;border:1.5px solid #E8E0D2;border-right:none;font-size:14px;outline:none;font-family:'Inter',sans-serif;">
        <button type="submit"
                style="padding:13px 20px;background:#3D2A15;color:#F5EFE5;font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;border:none;cursor:pointer;font-family:'Inter',sans-serif;">
          Enter
        </button>
      </div>
      {%- if form.errors -%}
        <p style="font-size:13px;color:#B8753A;margin-top:12px;">Wrong password. Please try again.</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</body>
</html>
