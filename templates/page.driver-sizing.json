        "callout_HyNXJB": {
          "type": "callout",
          "settings": {
            "label": "For runs 6 m and longer:",
            "text": "Power the strip from both ends, or split into segments with separate feeds. This prevents voltage drop, where the far end of a long run appears dimmer than the start."
          }
        },
        "heading_CahKyL": {
          "type": "heading",
          "settings": {
            "text": "What driver to buy"
          }
        },
        "text_eBtDbA": {
          "type": "text",
          "settings": {
            "content": "<p>Use a 24V constant-voltage LED driver. For dimmable installations, choose a TRIAC-dimmable 24V driver and pair it with a compatible wall dimmer. KAYVA strip itself doesn't dim on its own — the driver controls dimming.</p>"
          }
        },
        "callout_Jq8qPN": {
          "type": "callout",
          "settings": {
            "label": "Always use a licensed electrician",
            "text": "for connecting the driver to mains power in Singapore. The low-voltage side (driver to strip) is safe to handle when unpowered."
