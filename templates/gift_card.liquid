{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ gift_card.initial_value | money_without_trailing_zeros }} Gift Card &ndash; {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <style>
    body { background:var(--color-cream); display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; }
    .gift-card { background:var(--color-white); max-width:480px; width:100%; padding:48px 40px; text-align:center; }
    .gift-card__logo { font-weight:600; font-size:22px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-dark-brown); margin-bottom:32px; display:block; text-decoration:none; }
    .gift-card__amount { font-size:52px; font-weight:300; color:var(--color-dark-brown); margin-bottom:8px; line-height:1; }
    .gift-card__balance { font-size:13px; color:var(--color-soft-brown); margin-bottom:32px; }
    .gift-card__code-wrap { margin-bottom:24px; }
    .gift-card__code-label { font-size:10px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-soft-brown); margin-bottom:10px; }
    .gift-card__code { font-size:22px; font-weight:600; letter-spacing:0.2em; color:var(--color-dark-brown); padding:18px 24px; border:1.5px solid var(--color-line); display:inline-block; }
    .gift-card__expiry { font-size:12px; color:var(--color-soft-brown); margin-bottom:32px; }
  </style>
</head>
<body>
  <div class="gift-card">
    <a href="{{ shop.url }}" class="gift-card__logo">{{ shop.name }}</a>

    <p class="gift-card__amount">{{ gift_card.initial_value | money_without_trailing_zeros }}</p>

    {%- if gift_card.balance != gift_card.initial_value -%}
      <p class="gift-card__balance">Current balance: {{ gift_card.balance | money }}</p>
    {%- endif -%}

    <div class="gift-card__code-wrap">
      <p class="gift-card__code-label">Gift card code</p>
      <div class="gift-card__code" id="gift-card-code">{{ gift_card.code | format_code }}</div>
    </div>

    {%- unless gift_card.expired or gift_card.enabled == false -%}
      <p class="gift-card__expiry">
        {%- if gift_card.expires_on -%}
          Expires {{ gift_card.expires_on | date: '%d %B %Y' }}
        {%- else -%}
          No expiry date
        {%- endif -%}
      </p>
    {%- endunless -%}

    {%- if gift_card.enabled -%}
      <div style="display:flex; flex-direction:column; gap:12px; align-items:center;">
        <a href="{{ shop.url }}" class="btn btn--primary">Shop now</a>
        <button onclick="window.print()"
                style="font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-soft-brown); background:none; border:none; cursor:pointer; font-family:'Inter',sans-serif;">
          Print gift card
        </button>
      </div>
    {%- else -%}
      <p style="font-size:14px; color:var(--color-soft-brown);">This gift card has been disabled.</p>
    {%- endif -%}
  </div>
</body>
</html>
