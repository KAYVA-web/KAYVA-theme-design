<div class="page-width--narrow section" style="max-width:480px;">
  <h1 class="section-heading" style="margin-bottom:8px; text-align:center;">Reset password</h1>
  <p style="font-size:14px; color:var(--color-soft-brown); text-align:center; margin-bottom:var(--spacing-lg);">
    Enter your email and we&rsquo;ll send you a reset link.
  </p>

  {%- form 'recover_customer_password' -%}
    {%- if form.posted_successfully? -%}
      <p style="font-size:14px; color:var(--color-warm-brown); text-align:center; padding:16px; background:var(--color-cream); margin-bottom:20px;">
        Check your email for a reset link.
      </p>
    {%- endif -%}
    {%- if form.errors -%}
      <p style="font-size:13px; color:#c0392b; margin-bottom:16px; padding:12px 16px; background:#fef2f2; border:1px solid #fecaca;">
        {{ form.errors | default_errors }}
      </p>
    {%- endif -%}

    <div class="field" style="margin-bottom:24px;">
      <label class="field__label" for="recover-email">Email</label>
      <input class="field__input" type="email" name="email" id="recover-email"
             autocomplete="email" autocorrect="off" autocapitalize="off" required>
    </div>

    <button type="submit" class="btn btn--primary btn--full">Send reset link</button>
  {%- endform -%}

  <p style="text-align:center; margin-top:20px; font-size:13px; color:var(--color-soft-brown);">
    <a href="{{ routes.account_login_url }}" style="color:var(--color-warm-brown);">&larr; Back to sign in</a>
  </p>
</div>
