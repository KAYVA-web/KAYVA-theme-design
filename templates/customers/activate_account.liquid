<div class="page-width--narrow section" style="max-width:480px;">
  <h1 class="section-heading" style="margin-bottom:8px; text-align:center;">Activate account</h1>
  <p style="font-size:14px; color:var(--color-soft-brown); text-align:center; margin-bottom:var(--spacing-lg);">
    Create a password to activate your account.
  </p>

  {%- form 'activate_customer_password' -%}
    {%- if form.errors -%}
      <p style="font-size:13px; color:#c0392b; margin-bottom:16px; padding:12px 16px; background:#fef2f2; border:1px solid #fecaca;">
        {{ form.errors | default_errors }}
      </p>
    {%- endif -%}

    <div class="field" style="margin-bottom:16px;">
      <label class="field__label" for="activate-password">Password</label>
      <input class="field__input" type="password" name="customer[password]" id="activate-password"
             autocomplete="new-password" required>
    </div>

    <div class="field" style="margin-bottom:24px;">
      <label class="field__label" for="activate-password-confirm">Confirm password</label>
      <input class="field__input" type="password" name="customer[password_confirmation]" id="activate-password-confirm"
             autocomplete="new-password" required>
    </div>

    <button type="submit" class="btn btn--primary btn--full">Activate account</button>
  {%- endform -%}
</div>
