<section class="section">
  <div class="page-width">

    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:var(--spacing-xl); flex-wrap:wrap; gap:12px;">
      <div>
        <p class="label" style="margin-bottom:8px;">Order {{ order.name }}</p>
        <h1 class="section-heading">{{ order.created_at | date: '%d %B %Y' }}</h1>
      </div>
      <a href="{{ routes.account_url }}"
         style="font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-soft-brown);">
        &larr; Back to account
      </a>
    </div>

    <!-- Status pills -->
    <div style="display:flex; gap:12px; margin-bottom:var(--spacing-xl); flex-wrap:wrap;">
      <span class="badge">Payment: {{ order.financial_status_label }}</span>
      <span class="badge">Fulfilment: {{ order.fulfillment_status_label }}</span>
    </div>

    <!-- Line items -->
    <div style="border:1px solid var(--color-line); margin-bottom:var(--spacing-lg);">
      {%- for line_item in order.line_items -%}
        <div style="display:grid; grid-template-columns:80px 1fr auto; gap:16px; padding:16px 20px; border-bottom:1px solid var(--color-line); align-items:center;">
          <div style="background:var(--color-cream); aspect-ratio:1; overflow:hidden;">
            {%- if line_item.image -%}
              <img src="{{ line_item.image | image_url: width: 160 }}"
                   alt="{{ line_item.title | escape }}"
                   style="width:100%; height:100%; object-fit:cover;" loading="lazy">
            {%- endif -%}
          </div>
          <div>
            <p style="font-size:14px; font-weight:600; color:var(--color-dark-brown);">{{ line_item.product.title }}</p>
            {%- unless line_item.variant.title == 'Default Title' -%}
              <p style="font-size:12px; color:var(--color-soft-brown);">{{ line_item.variant.title }}</p>
            {%- endunless -%}
            <p style="font-size:12px; color:var(--color-soft-brown);">Qty: {{ line_item.quantity }}</p>
          </div>
          <p style="font-size:14px; font-weight:500; color:var(--color-dark-brown);">{{ line_item.final_line_price | money }}</p>
        </div>
      {%- endfor -%}
    </div>

    <!-- Totals -->
    <div style="max-width:320px; margin-left:auto;">
      <div style="display:flex; justify-content:space-between; padding:10px 0; font-size:13px; color:var(--color-ink); border-bottom:1px solid var(--color-line);">
        <span>Subtotal</span><span>{{ order.subtotal_price | money }}</span>
      </div>
      {%- for shipping_method in order.shipping_methods -%}
        <div style="display:flex; justify-content:space-between; padding:10px 0; font-size:13px; color:var(--color-ink); border-bottom:1px solid var(--color-line);">
          <span>Shipping — {{ shipping_method.title }}</span><span>{{ shipping_method.price | money }}</span>
        </div>
      {%- endfor -%}
      {%- for tax_line in order.tax_lines -%}
        <div style="display:flex; justify-content:space-between; padding:10px 0; font-size:13px; color:var(--color-ink); border-bottom:1px solid var(--color-line);">
          <span>{{ tax_line.title }} ({{ tax_line.rate | times: 100 }}%)</span><span>{{ tax_line.price | money }}</span>
        </div>
      {%- endfor -%}
      <div style="display:flex; justify-content:space-between; padding:14px 0; font-size:16px; font-weight:600; color:var(--color-dark-brown);">
        <span>Total</span><span>{{ order.total_price | money }}</span>
      </div>
    </div>

    <!-- Shipping address -->
    {%- if order.shipping_address -%}
      <div style="margin-top:var(--spacing-xl);">
        <h2 style="font-size:11px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-dark-brown); margin-bottom:var(--spacing-sm);">Shipping address</h2>
        <div style="font-size:14px; line-height:1.8; color:var(--color-ink);">{{ order.shipping_address | format_address }}</div>
      </div>
    {%- endif -%}

  </div>
</section>
