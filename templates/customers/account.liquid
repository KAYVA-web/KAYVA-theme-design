{% layout 'theme' %}
<section class="section">
  <div class="page-width">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--spacing-xl);">
      <h1 class="section-heading">My Account</h1>
      <a href="{{ routes.account_logout_url }}" style="font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-soft-brown);">Sign out</a>
    </div>
    <h2 style="font-size:13px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-dark-brown); margin-bottom:var(--spacing-md);">Order history</h2>
    {%- if customer.orders.size > 0 -%}
      <table style="width:100%; border-collapse:collapse; font-size:13px;">
        <thead>
          <tr style="border-bottom:2px solid var(--color-line);">
            <th style="text-align:left; padding:10px 0; color:var(--color-soft-brown); font-weight:500;">Order</th>
            <th style="text-align:left; padding:10px 0; color:var(--color-soft-brown); font-weight:500;">Date</th>
            <th style="text-align:left; padding:10px 0; color:var(--color-soft-brown); font-weight:500;">Status</th>
            <th style="text-align:right; padding:10px 0; color:var(--color-soft-brown); font-weight:500;">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr style="border-bottom:1px solid var(--color-line);">
              <td style="padding:12px 0;"><a href="{{ order.customer_url }}" style="color:var(--color-warm-brown);">{{ order.name }}</a></td>
              <td style="padding:12px 0; color:var(--color-ink);">{{ order.created_at | date: '%d %b %Y' }}</td>
              <td style="padding:12px 0; color:var(--color-ink);">{{ order.financial_status_label }}</td>
              <td style="padding:12px 0; text-align:right; font-weight:500; color:var(--color-dark-brown);">{{ order.total_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <p style="font-size:14px; color:var(--color-soft-brown);">You haven't placed any orders yet.</p>
      <a href="/collections/all" class="btn btn--primary" style="margin-top:24px;">Shop the range</a>
    {%- endif -%}
  </div>
</section>
