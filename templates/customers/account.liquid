<section class="section">
  <div class="page-width">

    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:var(--spacing-xl); flex-wrap:wrap; gap:12px;">
      <div>
        <p class="label" style="margin-bottom:8px;">Account</p>
        <h1 class="section-heading">{{ customer.first_name }} {{ customer.last_name }}</h1>
      </div>
      <a href="{{ routes.account_logout_url }}"
         style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-soft-brown); border-bottom:1px solid currentColor; padding-bottom:2px;">
        Sign out
      </a>
    </div>

    <!-- Order history -->
    <h2 style="font-size:11px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-dark-brown); margin-bottom:var(--spacing-md);">
      Order history
    </h2>

    {%- if customer.orders.size > 0 -%}
      <div style="border:1px solid var(--color-line);">
        <table style="width:100%; border-collapse:collapse; font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid var(--color-line); background:var(--color-cream);">
              <th style="text-align:left; padding:12px 16px; font-size:10px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-soft-brown);">Order</th>
              <th style="text-align:left; padding:12px 16px; font-size:10px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-soft-brown);">Date</th>
              <th style="text-align:left; padding:12px 16px; font-size:10px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-soft-brown);">Payment</th>
              <th style="text-align:left; padding:12px 16px; font-size:10px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-soft-brown);">Fulfilment</th>
              <th style="text-align:right; padding:12px 16px; font-size:10px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--color-soft-brown);">Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr style="border-bottom:1px solid var(--color-line);">
                <td style="padding:14px 16px;">
                  <a href="{{ order.customer_url }}" style="color:var(--color-warm-brown); font-weight:500;">
                    {{ order.name }}
                  </a>
                </td>
                <td style="padding:14px 16px; color:var(--color-ink);">{{ order.created_at | date: '%d %b %Y' }}</td>
                <td style="padding:14px 16px; color:var(--color-ink);">{{ order.financial_status_label }}</td>
                <td style="padding:14px 16px; color:var(--color-ink);">{{ order.fulfillment_status_label }}</td>
                <td style="padding:14px 16px; text-align:right; font-weight:500; color:var(--color-dark-brown);">{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- else -%}
      <div style="padding:var(--spacing-xl) 0; text-align:center; border:1px solid var(--color-line);">
        <p style="font-size:14px; color:var(--color-soft-brown); margin-bottom:24px;">No orders yet.</p>
        <a href="/collections/all" class="btn btn--primary">Shop the range</a>
      </div>
    {%- endif -%}

    <!-- Default address -->
    {%- if customer.default_address -%}
      <h2 style="font-size:11px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:var(--color-dark-brown); margin-top:var(--spacing-xl); margin-bottom:var(--spacing-md);">
        Default address
      </h2>
      <div style="font-size:14px; line-height:1.8; color:var(--color-ink); border:1px solid var(--color-line); padding:20px 24px; max-width:320px;">
        {{ customer.default_address | format_address }}
      </div>
      <a href="{{ routes.account_addresses_url }}"
         style="display:inline-block; margin-top:12px; font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--color-warm-brown); border-bottom:1px solid currentColor; padding-bottom:2px;">
        Manage addresses
      </a>
    {%- endif -%}

  </div>
</section>
